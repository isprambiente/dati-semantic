  dcterms:description "Vocabolario controllato degli indicatori climatici (valori normali, clima recente, periodi) utilizzato per la pubblicazione dei dati climatici."@it ,
                  "Controlled vocabulary of climate indicators (normal values, recent climate, periods) used for publishing climate data."@en ;
  rdfs:comment "Vocabolario controllato degli indicatori climatici (valori normali, clima recente, periodi) utilizzato per la pubblicazione dei dati climatici."@it ,
                  "Controlled vocabulary of climate indicators (normal values, recent climate, periods) used for publishing climate data."@en ;                  
  dcterms:identifier "https://w3id.org/italia/env/vocab/climate/indicators" ;
  dcterms:language <http://publications.europa.eu/resource/authority/language/ITA>,
               <http://publications.europa.eu/resource/authority/language/ENG> ;
  dcterms:issued "2026-06-18"^^xsd:date ;
  dcterms:modified "2026-06-18"^^xsd:date ;
  dcterms:creator <https://w3id.org/italia/env/ld/common/organisation/001> ;
