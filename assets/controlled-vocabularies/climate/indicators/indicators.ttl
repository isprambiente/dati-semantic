############################################################
# 2. SKOS CONCEPTS — URI ISPRA ESPLICITE
############################################################

########## TOP CONCEPTS ##########

<https://w3id.org/italia/env/vocab/climate/indicators/normal-values>
    a skos:Concept ;
    dcterms:identifier "normal-values" ;
    skos:prefLabel "Valori normali - Temperatura e precipitazione"@it ;
    skos:prefLabel "Normal values - Temperature and precipitation"@en ;
    skos:definition "Valori medi delle variabili climatiche relativi al periodo e all'area geografica di interesse, calcolati su un periodo di trent'anni, come definito dalla WMO. Ogni 10 anni viene aggiornato tale periodo di riferimento."@it ;
    skos:definition "Mean values of climate variables related to the period and geographical area of interest, calculated over a thirty-year period as defined by the WMO. This reference period is updated every 10 years."@en ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/recent-climate>
    a skos:Concept ;
    dcterms:identifier "recent-climate" ;
    skos:prefLabel "Clima recente - Temperatura e precipitazione"@it ;
    skos:prefLabel "Recent climate - Temperature and precipitation"@en ;
    skos:definition "Indicatori climatici di temperatura e precipitazione, relativi a periodo e area geografica di interesse, per gli ultimi anni."@it ;
    skos:definition "Temperature and precipitation climate indicators, related to the time period and geographic area of interest, for recent years."@en ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

########## VARIABLES ##########

<https://w3id.org/italia/env/vocab/climate/indicators/mean-temperature-normal>
    a skos:Concept ;
    dcterms:identifier "mean-temperature-normal" ;
    skos:prefLabel "Valore normale della temperatura media"@it ;
    skos:prefLabel "Normal mean temperature"@en ;
    skos:definition "Temperatura media calcolata come valore climatologico su un periodo di riferimento trentennale definito dalla WMO. Unità: °C."@it ;
    skos:definition "Mean temperature computed as a climatological value over a WMO-defined 30‑year reference period. Unit: °C."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/max-temperature-normal>
    a skos:Concept ;
    dcterms:identifier "max-temperature-normal" ;
    skos:prefLabel "Valore normale della temperatura massima"@it ;
    skos:prefLabel "Normal maximum temperature"@en ;
    skos:definition "Temperatura massima calcolata come valore climatologico su un periodo di riferimento trentennale definito dalla WMO. Unità: °C."@it ;
    skos:definition "Maximum temperature computed as a climatological value over a WMO-defined 30‑year reference period. Unit: °C."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/min-temperature-normal>
    a skos:Concept ;
    dcterms:identifier "min-temperature-normal" ;
    skos:prefLabel "Valore normale della temperatura minima"@it ;
    skos:prefLabel "Normal minimum temperature"@en ;
    skos:definition "Temperatura minima calcolata come valore climatologico su un periodo di riferimento trentennale definito dalla WMO. Unità: °C."@it ;
    skos:definition "Minimum temperature computed as a climatological value over a WMO-defined 30‑year reference period. Unit: °C."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/cumulative-precipitation-normal>
    a skos:Concept ;
    dcterms:identifier "cumulative-precipitation-normal" ;
    skos:prefLabel "Valore normale della precipitazione cumulata"@it ;
    skos:prefLabel "Normal cumulative precipitation"@en ;
    skos:definition "Totale delle precipitazioni cumulate calcolato come valore climatologico su un periodo di riferimento trentennale definito dalla WMO. Unità: mm."@it ;
    skos:definition "Total accumulated precipitation computed as a climatological value over a WMO-defined 30‑year reference period. Unit: mm."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

########## TYPES (GENERAL) ##########

############################################################
# ANOMALIE SPECIFICHE
############################################################

<https://w3id.org/italia/env/vocab/climate/indicators/mean-temperature-anomaly>
    a skos:Concept ;
    dcterms:identifier "mean-temperature-anomaly" ;
    skos:prefLabel "Anomalia della temperatura media"@it ;
    skos:prefLabel "Mean temperature anomaly"@en ;
    skos:definition "Deviazione del valore attuale della temperatura media rispetto al più recente periodo di riferimento trentennale definito dalla WMO. Unità: °C."@it ;
    skos:definition "Deviation of actual mean temperature from the latest 30‑year WMO reference period. Unit: °C."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/max-temperature-anomaly>
    a skos:Concept ;
    dcterms:identifier "max-temperature-anomaly" ;
    skos:prefLabel "Anomalia della temperatura massima"@it ;
    skos:prefLabel "Maximum temperature anomaly"@en ;
    skos:definition "Deviazione del valore attuale della temperatura massima rispetto al più recente periodo di riferimento trentennale definito dalla WMO. Unità: °C."@it ;
    skos:definition "Deviation of actual maximum temperature from the latest 30‑year WMO reference period. Unit: °C."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/min-temperature-anomaly>
    a skos:Concept ;
    dcterms:identifier "min-temperature-anomaly" ;
    skos:prefLabel "Anomalia della temperatura minima"@it ;
    skos:prefLabel "Minimum temperature anomaly"@en ;
    skos:definition "Deviazione del valore attuale della temperatura minima rispetto al più recente periodo di riferimento trentennale definito dalla WMO. Unità: °C."@it ;
    skos:definition "Deviation of actual minimum temperature from the latest 30‑year WMO reference period. Unit: °C."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/cumulative-precipitation-anomaly>
    a skos:Concept ;
    dcterms:identifier "cumulative-precipitation-anomaly" ;
    skos:prefLabel "Anomalia della precipitazione cumulata"@it ;
    skos:prefLabel "Cumulative precipitation anomaly"@en ;
    skos:definition "Deviazione del valore attuale della precipitazione cumulata rispetto al più recente periodo di riferimento trentennale definito dalla WMO. Unità: mm."@it ;
    skos:definition "Deviation of actual cumulative precipitation from the latest 30‑year WMO reference period. Unit: mm."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/mean-temperature-absolute>
    a skos:Concept ;
    dcterms:identifier "mean-temperature-absolute" ;
    skos:prefLabel "Valore attuale della temperatura media"@it ;
    skos:prefLabel "Actual mean temperature"@en ;
    skos:definition "Valore della temperatura media nel periodo e nell'area geografica di interesse, per diverse aggregazioni temporali (mensili/stagionali/annuali)."@it ;
    skos:definition "Value of the mean temperature for the period and geographical area of interest, across different time aggregations (monthly/seasonal/annual)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/max-temperature-absolute>
    a skos:Concept ;
    dcterms:identifier "max-temperature-absolute" ;
    skos:prefLabel "Valore attuale della temperatura massima"@it ;
    skos:prefLabel "Actual maximum temperature"@en ;
    skos:definition "Valore della temperatura massima media nel periodo e nell'area geografica di interesse, per diverse aggregazioni temporali (mensili/stagionali/annuali)."@it ;
    skos:definition "Value of the mean maximum temperature for the period and geographical area of interest, across different time aggregations (monthly/seasonal/annual)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/min-temperature-absolute>
    a skos:Concept ;
    dcterms:identifier "min-temperature-absolute" ;
    skos:prefLabel "Valore attuale della temperatura minima"@it ;
    skos:prefLabel "Actual minimum temperature"@en ;
    skos:definition "Valore della temperatura minima media nel periodo e nell'area geografica di interesse, per diverse aggregazioni temporali (mensili/stagionali/annuali)."@it ;
    skos:definition "Value of the mean minimum temperature for the period and geographical area of interest, across different time aggregations (monthly/seasonal/annual)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

<https://w3id.org/italia/env/vocab/climate/indicators/cumulative-precipitation-absolute>
    a skos:Concept ;
    dcterms:identifier "cumulative-precipitation-absolute" ;
    skos:prefLabel "Valore attuale della precipitazione cumulata"@it ;
    skos:prefLabel "Actual cumulative precipitation"@en ;
    skos:definition "Valore della precipitazione cumulata nel periodo e nell'area geografica di interesse, per diverse aggregazioni temporali (mensili/stagionali/annuali)."@it ;
    skos:definition "Value of the cumulative precipitation for the period and geographical area of interest, across different time aggregations (monthly/seasonal/annual)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/climate/indicators/recent-climate> ;
    skos:inScheme <https://w3id.org/italia/env/vocab/climate/indicators> .

########## PERIODS ##########

<https://w3id.org/italia/env/vocab/climate/indicators/period-1961-1990>
    a skos:Concept ;
    dcterms:identifier "period-1961-1990" ;
    skos:prefLabel "1961-1990"@it ;
    skos:prefLabel "1961-1990"@en ;
    skos:definition "Trentennio climatologico di riferimento WMO utilizzato per il calcolo dei valori normali climatici del passato."@it ;
    skos:definition "WMO climatological reference 30‑year period used for computing past climatic normal values."@en ;
    skos:related <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> .

<https://w3id.org/italia/env/vocab/climate/indicators/period-1971-2000>
