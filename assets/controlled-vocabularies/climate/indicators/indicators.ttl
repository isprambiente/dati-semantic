    dcterms:identifier "period-1971-2000" ;
    skos:prefLabel "1971-2000"@it ;
    skos:prefLabel "1971-2000"@en ;
    skos:definition "Trentennio climatologico di riferimento WMO utilizzato per il calcolo dei valori normali climatici del passato."@it ;
    skos:definition "WMO climatological reference 30‑year period used for computing past climatic normal values."@en ;
    skos:related <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> .

<https://w3id.org/italia/env/vocab/climate/indicators/period-1981-2010>
    a skos:Concept ;
    dcterms:identifier "period-1981-2010" ;
    skos:prefLabel "1981-2010"@it ;
    skos:prefLabel "1981-2010"@en ;
    skos:definition "Trentennio climatologico di riferimento WMO utilizzato per il calcolo dei valori normali climatici del passato."@it ;
    skos:definition "WMO climatological reference 30‑year period used for computing past climatic normal values."@en ;
    skos:related <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> .

<https://w3id.org/italia/env/vocab/climate/indicators/period-1991-2020>
    a skos:Concept ;
    dcterms:identifier "period-1991-2020" ;
    skos:prefLabel "1991-2020"@it ;
    skos:prefLabel "1991-2020"@en ;
    skos:definition "Il più recente trentennio climatologico di riferimento WMO utilizzato sia per il calcolo dei valori normali climatici sia come periodo di riferimento per le anomalie del clima recente."@it ;
    skos:definition "The most recent WMO climatological reference 30‑year period used both for computing climatic normal values and as the reference period for recent‑climate anomalies."@en ;
    skos:related <https://w3id.org/italia/env/vocab/climate/indicators/normal-values> .

########## AREA LEVELS ##########

<https://w3id.org/italia/env/vocab/climate/indicators/national-aggregation>
    a skos:Concept ;
    dcterms:identifier "national-aggregation" ;
    skos:prefLabel "Aggregazione nazionale"@it ;
    skos:prefLabel "National aggregation"@en ;
