  dcterms:rightsHolder <https://w3id.org/italia/env/ld/common/organisation/001> ;
  owl:versionInfo "Version 1.0 - June 2026 - First publication of the Climate Indicators controlled vocabulary"@en ,
                  "Versione 1.0 - Giugno 2026 - Prima pubblicazione del vocabolario controllato degli indicatori climatici"@it ;
  dcterms:type <http://purl.org/adms/assettype/Taxonomy> ;
  adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
  xkos:numberOfLevels "2" ;
  ndc:keyConcept "climate-indicators" ;
  dcterms:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
  dcat:contactPoint <https://w3id.org/italia/env/ld/common/organization/001-LD> ;
  dcat:distribution <https://w3id.org/italia/env/ld/common/distribution/climate-indicators-RDF-TURTLE>,
                    <https://w3id.org/italia/env/ld/common/distribution/climate-indicators-CSV> ;
  dcat:keyword "climate"@en ,
