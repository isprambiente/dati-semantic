# =========================================================================
# MACRO-ECOSYSTEM 1: Settlements and other artificial areas
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1" ;
    dcterms:identifier "1" ;
    skos:prefLabel "Settlements and other artificial areas"@en ;
    skos:definition "This class represents human habitats, i.e. ecosystems that are strongly modified by people and that are characterised by buildings and other man-made structures. It includes dispersed and dense residential, industrial, commercial, and transport areas, urban green areas, mineral and gravel extraction sites, dumping and construction sites. The class excludes peat extraction sites (classified under ‘Inland wetlands’). The class has also been labelled ‘urban ecosystems’."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.1" ;
    dcterms:identifier "1.1" ;
    skos:prefLabel "Continuous settlement area"@en ;
    skos:definition "Also designated as continuous urban area or fabric. The continuous settlement area type is assigned when settlement structures and transport networks are dominating the surface area. At least 80% of the land surface in the ecosystem asset is covered by impermeable features such as buildings, roads and artificially surfaced areas."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/111> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.2" ;
    dcterms:identifier "1.2" ;
    skos:prefLabel "Discontinuous settlement area"@en ;
    skos:definition "Also designated as discontinuous urban area or fabric. The discontinuous settlement area type is assigned when settlement structures and transport networks associated with vegetated areas and bare surfaces are present and occupy significant surfaces in a discontinuous spatial pattern. The impermeable features such as buildings, roads and artificially surfaced areas range from 30 to 80 % land coverage in the ecosystem asset."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/112> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3" ;
    dcterms:identifier "13" ;
    skos:prefLabel "Infrastructure"@en ;
    skos:definition "This includes land used for transport infrastructure such as roads, airports and ports, including associated areas (e.g. planted trees and bushes lines or spontaneous vegetation, such as grass verges), and artificial areas other than buildings that are used for commercial and industrial purposes including extraction sites, dump areas, and construction sites."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/121> ; # Industrial or commercial units
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/122> ; # Road and rail networks and associated land
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/123> ; # Port areas
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/124> ; # Airports
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT3.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.7> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.4" ;
    dcterms:identifier "14" ;
    skos:prefLabel "Urban greenspace"@en ;
    skos:definition "Areas with vegetation within or partly embraced by urban fabric. This class is assigned for urban greenery, which usually has recreational or ornamental character and is usually accessible for the public. Includes small urban water bodies. Areas with soil sealing above 30% should be moved to class 1.1 or 1.2."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/141> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/142> ,
                    <https://global-ecosystems.org/explore/groups/T7.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.4> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.5" ;
    dcterms:identifier "15" ;
    skos:prefLabel "Other artificial areas"@en ;
    skos:definition "Areas that are artificial but do not fall under the other level 2 categories of settlements and artificial areas. This includes e.g. permanent green houses, cemeteries even if predominantly green. Countries should also record here types of artificial land of specific national importance, such as archaeological sites or others, if they do not belong to any of the level 2 categories 1.1 -1.4. Countries should inform what they cover in this category in a footnote in the questionnaire."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/142> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/141> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/112> ,
                    <https://global-ecosystems.org/explore/groups/T7.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5.3> .

# --- LEVEL 3 ---

# --- Children of 1.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.1.1" ;
    dcterms:identifier "1.1.1" ;
    skos:prefLabel "Continuous residential area"@en ;
    skos:definition "Urban areas where buildings, roads and other impermeable surfaces occupy at least 80% of the land, and with continuous or nearly continuous buildings, which may be houses, flats or buildings occupied for only part of the day."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/J1.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.1.2" ;
    dcterms:identifier "1.1.2" ;
    skos:prefLabel "Continuous commercial and industrial area"@en ;
    skos:definition "Areas with current industrial or commercial use including services (e.g., public libraries, government offices). Includes office blocks, factories, industrial units, large animal-rearing batteries and large farm units."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/J1.4> .

# --- Children of 1.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.2.1" ;
    dcterms:identifier "1.2.1" ;
    skos:prefLabel "Discontinuous residential area"@en ;
    skos:definition "Residential building areas in suburbs and villages where buildings and other impermeable surfaces occupy between 30% and 80% of the land area."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/J1.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.2.2" ;
    dcterms:identifier "1.2.2" ;
    skos:prefLabel "Discontinuous commercial and industrial area"@en ;
    skos:definition "Commercial and industrial building areas in suburbs and villages where buildings and other impermeable surfaces occupy between 30% and 80% of the land area."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/J2.3> .

# --- Children of 1.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.1" ;
    dcterms:identifier "131" ;
    skos:prefLabel "Road and rail networks and associated land"@en ;
    skos:definition "Motorways, railways, including associated installations (stations, platforms, embankments), including associated green areas (e.g. planted trees and bushes lines or spontaneous vegetation, such as grass verges), excluding dams and dykes."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/122> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.2" ;
    dcterms:identifier "132" ;
    skos:prefLabel "Port areas"@en ;
    skos:definition "Infrastructure of port areas, including quays, dockyards and marinas, including associated green areas."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/123> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.3" ;
    dcterms:identifier "133" ;
    skos:prefLabel "Airports"@en ;
    skos:definition "Airport installations: runways, buildings and associated land, including associated green areas."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/124> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.4" ;
    dcterms:identifier "134" ;
    skos:prefLabel "Other infrastructure"@en ;
    skos:definition "Other infrastructure (e.g. water purification plants, energy plants, transforming stations), including associated green areas."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/122> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.5" ;
    dcterms:identifier "135" ;
    skos:prefLabel "Mineral extraction sites"@en ;
    skos:scopeNote "Excludes peat extraction sites, see 7.3.1"@en ;
    skos:definition "Open-pit extraction sites of construction materials (sandpits, quarries) or minerals (open-cast mines). Includes flooded mining pits."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/131> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.6" ;
    dcterms:identifier "136" ;
    skos:prefLabel "Dump areas"@en ;
    skos:definition "Landfill or mine dump sites, industrial or public."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/132> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3.7> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.3.7" ;
    dcterms:identifier "137" ;
    skos:prefLabel "Construction sites"@en ;
    skos:definition "Spaces under construction development, soil or bedrock excavations, earthworks. This class is assigned for areas where landscape is affected by human activities, changed or modified into artificial surfaces, being in a state of anthropogenic transition."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/133> .

# --- Children of 1.4 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.4.1" ;
    dcterms:identifier "141" ;
    skos:prefLabel "Parks (including Zoos and botanical gardens)"@en ;
    skos:definition "Varied green spaces within towns and cities. They may include small woods, mown lawns, small water bodies including streams (which may be semi-natural or artificial), flowerbeds and shrubberies, and semi-natural grassland or woodland enclaves. Grasslands, usually mowed, composed of native or sometimes exotic grasses, constituting elements of urban parks. Zoological and botanical gardens are included. Urban gardens (e.g. community gardens) are included."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/X11> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E2.64> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/I2.23> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.4.2" ;
    dcterms:identifier "142" ;
    skos:prefLabel "Sports and recreation sites"@en ;
    skos:definition "This class is assigned for green areas used for sports, leisure and recreation purposes, for example camping grounds, sports grounds, leisure parks, golf courses, racecourses, etc. The class applies for sites larger than the MMU within and outside of urban zones. Sport sites without green (e.g., a racing track) are excluded."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/142> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.4.3" ;
    dcterms:identifier "143" ;
    skos:prefLabel "Other urban green"@en ;
    skos:definition "Other, non-specified areas within or partly embraced by urban fabric, such as tree alleys, or green areas possibly with the presence of abandoned buildings or infrastructure."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/141> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.4.4" ;
    dcterms:identifier "144" ;
    skos:prefLabel "Urban blue"@en ;
    skos:definition "Lakes or substantial ponds in urban parks, or water bodies in settlements used for recreation."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/J5.3> .

# --- Children of 1.5 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.5.1" ;
    dcterms:identifier "151" ;
    skos:prefLabel "Permanent Greenhouses"@en ;
    skos:definition "Permanent structures with hard or soft transparent surfaces dispersed within the urban, rural or natural environment established for the purpose of agricultural activities, small-scale commercial, artisanal or industrial activities, recreation, research, environmental protection. Excludes non-permanent installations such as film tunnels on cropland to protect crops from weather conditions."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/J2.4> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.5.2" ;
    dcterms:identifier "152" ;
    skos:prefLabel "Cemeteries"@en ;
    skos:definition "This class includes sites designated as burial grounds, associated with church buildings or separate from them. The character of cemeteries varies substantially across Europe, for example they may have a lot of tree cover or none at all, thus more a land use than land cover/ecosystem classification. The use of this class is therefore at the discretion of countries and requires a clear meta data documentation."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "1.5.3" ;
    dcterms:identifier "153" ;
    skos:prefLabel "Archaeological sites"@en ;
    skos:definition "This class includes areas formally recognised as of archaeological importance. The ecological character of such sites varies substantially across Europe and within countries, for example they may have a lot of tree cover or none at all, thus more a land use than land cover/ecosystem classification. The use of this class is therefore at the discretion of countries and requires a clear meta data documentation."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/1.5> .

# =========================================================================
# MACRO-ECOSYSTEM 2: Cropland
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2" ;
    dcterms:identifier "2" ;
    skos:prefLabel "Cropland"@en ;
    skos:definition "Croplands are food production areas including both intensively managed cropland, extensively managed cropland, and multifunctional areas. They include areas with perennial and annual crops, and agro-ecosystems with significant coverage of natural vegetation (agricultural mosaics). Cropland may include agro-forestry areas such as cork and holm oak stands (see respective classes at level 2). Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1" ;
    dcterms:identifier "21" ;
    skos:prefLabel "Annual cropland"@en ;
    skos:definition "Cropland planted for annually or regularly harvested crops other than those that carry trees or shrubs. They include fields of cereals, of sunflowers and other oil seed plants, of beets, legumes, fodder, potatoes, and other forbs. Croplands comprise intensively cultivated fields, fallow land, temporary grass for silage and grazing as well as traditionally and extensively cultivated crops with little or no chemical fertilisation or pesticide application. Faunal and floral quality and diversity depend on the intensity of agricultural use and on the presence of borders of (semi-)natural vegetation and woody structures between fields. Includes non-permanent greenhouse installations such as film tunnels. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/211> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/212> ,
                    <https://global-ecosystems.org/explore/groups/T7.1> ;
    skos:scopeNote "Partially: elements of 2.4 Heterogenous agricultural areas (depending on mapping rules and data sources used)"@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.7> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.8> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.9> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.10> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.11> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.2" ;
    dcterms:identifier "22" ;
    skos:prefLabel "Rice fields"@en ;
    skos:definition "See level 3 – 2.2.1"@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/213> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/F3.3> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.3" ;
    dcterms:identifier "23" ;
    skos:prefLabel "Permanent crops"@en ;
    skos:definition "Crops not under a rotation system which provide repeated harvests and occupy the land for a long period before they are renewed. Mainly plantations of woody crops, e.g. vineyards, fruit and berry plantations, olive groves. Excludes pastures, grazing lands and forests. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/221> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/222> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/223> ,
                    <https://global-ecosystems.org/explore/groups/T7.3> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.7> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.8> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.9> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.10> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3.11> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.4" ;
    dcterms:identifier "24" ;
    skos:prefLabel "Agro-forestry areas"@en ;
    skos:definition "Crops combined with scattered tree stands , with a canopy cover, in general, between 10% and 30%. A typical expression are the Iberian dehesas and montados. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/244> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T4.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.5" ;
    dcterms:identifier "25" ;
    skos:prefLabel "Mixed farmland"@en ;
    skos:definition "Also designated as heterogeneous agricultural areas. Includes: Non-permanent crops (arable lands) associated with permanent crops on the same plot of farmland; juxtaposition or mosaics of small parcels of diverse annual crops, pasture/grassland and/or permanent crops; areas principally occupied by agriculture, interspersed with significant natural areas; and annual crops or grazing land under the wooded cover of forestry species (i.e., agroforestry). Characteristic is that none of these land cover types is dominant in the given unit. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/241> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/242> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/243> ,
                    <https://global-ecosystems.org/explore/groups/T7.1> ,
                    <https://global-ecosystems.org/explore/groups/T7.2> ,
                    <https://global-ecosystems.org/explore/groups/T7.3> ,
                    <https://global-ecosystems.org/explore/groups/T7.5> ;
    skos:scopeNote "Maps to CORINE 2.4 (Heterogeneous agricultural areas) minus CLC 2.4.4 (Agro-forestry areas)"@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.5.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.6" ;
    dcterms:identifier "26" ;
    skos:prefLabel "Other farmland"@en ;
    skos:definition "Other types of farmland not included in the other categories of cropland such as nurseries, Christmas tree plantations and bioenergy grasses and short rotation coppice. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2> ;
    skos:scopeNote "Depending on mapping rules: elements of CLC groups 2.1, 2.2, 2.4"@en ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.3> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.4> .

# --- LEVEL 3 ---

# --- Children of 2.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.1" ;
    dcterms:identifier "211" ;
    skos:prefLabel "Cereals excluding rice excluding maize"@en ;
    skos:scopeNote "Cereals excluding rice (C1000) excluding maize (C1500)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/I1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.2" ;
    dcterms:identifier "212" ;
    skos:prefLabel "Maize"@en ;
    skos:scopeNote "Maize (C1500 + G3000)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.3" ;
    dcterms:identifier "213" ;
    skos:prefLabel "Dry pulses and protein crops"@en ;
    skos:scopeNote "Dry pulses and protein crops (P0000)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.4" ;
    dcterms:identifier "214" ;
    skos:prefLabel "Root crops, like sugar beet and potatoes"@en ;
    skos:scopeNote "Root crops, like sugar beet and potatoes (R0000)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.5" ;
    dcterms:identifier "215" ;
    skos:prefLabel "Vegetables (including melons) and strawberries"@en ;
    skos:scopeNote "Vegetables (including melons) and strawberries (V0000_S0000)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.6" ;
    dcterms:identifier "216" ;
    skos:prefLabel "Industrial crops including annual bioenergy crops"@en ;
    skos:scopeNote "Industrial crops including annual bioenergy crops (I0000)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.7> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.7" ;
    dcterms:identifier "217" ;
    skos:prefLabel "Flowers and ornamental plants (N0000)"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.8> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.8" ;
    dcterms:identifier "218" ;
    skos:prefLabel "Fallow land (Q0000)"@en ;
    skos:definition "Fallow land is all arable land either included in the crop rotation system or maintained in good agricultural and environmental condition, whether worked or not, but which will not be harvested for the duration of a crop year. The essential characteristic of fallow land is that it is left to recover, normally for the whole of a crop year. Fallow land may be bare land with no crops at all or land with spontaneous natural growth which may be used as feed or ploughed in or land sown exclusively for the production of green manure (green fallow). It includes arable land lying fallow for less than 5 years and arable land lying fallow for 5 years or more if for the purpose of fulfilling the ecological focus area."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.9> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.9" ;
    dcterms:identifier "219" ;
    skos:prefLabel "Temporary grasses (G1000)"@en ;
    skos:definition "Temporary grasses sown as intercrop, for silage and grazing."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.10> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.10" ;
    dcterms:identifier "2110" ;
    skos:prefLabel "Other crops"@en ;
    skos:definition "One component of croplands planted for annually or regularly harvested crops other than those that carry trees or shrubs. Croplands comprise intensively cultivated fields as well as traditionally and/or extensively cultivated crops with little or no chemical fertilisation or pesticide application. (Further categories may be added by Member States, depending upon nationally important crop types)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1.11> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.1.11" ;
    dcterms:identifier "2111" ;
    skos:prefLabel "Semi-natural elements associated with agricultural land use in annual cropland"@en ;
    skos:definition "Traditional agricultural land use and landscape elements including hedges, ponds, grassy margins etc. as part of the farmed area. Such remaining semi-natural elements are considered part of cropland (and grassland) and can be mapped separately. Treelines and hedgerows are often easiest to distinguish. Member States are requested to fully document the type of landscape elements included in this class where it is reported separately."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.1> .

# --- Children of 2.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.2.1" ;
    dcterms:identifier "221" ;
    skos:prefLabel "Rice fields"@en ;
    skos:scopeNote "Rice fields (C2000)"@en ;
    skos:definition "Inundated or inundatable fields used for the cultivation of rice (Oryza sativa). When not too heavily treated, they may provide substitution habitats for some wetland species, for example resident birds (e.g. ducks, rails and herons) and as feeding grounds for migratory birds."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/I1.4> .

# --- Children of 2.3 ---
