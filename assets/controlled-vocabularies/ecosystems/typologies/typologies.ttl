                    <https://eunis.eea.europa.eu/habitats/2485> .

# --- Children of 4.4 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.4.1" ;
    dcterms:identifier "441" ;
    skos:prefLabel "Mixed forests dominated by coniferous species"@en ;
    skos:definition "Vegetation formation composed principally of trees, including shrub and bush understorey, where coniferous species moderately predominate, in terms of canopy cover (typically between 60 % to 80 % canopy cover). The class includes forests that are a mix of native broadleaved trees and spontaneously established spruce and pine trees. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/313> ,
                    <https://eunis.eea.europa.eu/habitats/22351> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.4.2" ;
    dcterms:identifier "442" ;
    skos:prefLabel "Mixed forests dominated by broadleaved species"@en ;
    skos:definition "Vegetation formation composed principally of trees, including shrub and bush understorey, where broadleaved species moderately predominate, in terms of canopy cover (typically between 60 % to 80 % canopy cover). The class includes forests that are a mix of native and spontaneously established trees. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/313> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.4.3" ;
    dcterms:identifier "443" ;
    skos:prefLabel "Other mixed forests including stands of non-native trees species that have long been established in European forest mixes."@en ;
    skos:definition "Vegetation formation composed principally of trees, including shrub and bush understorey, where neither broadleaved nor coniferous species predominate. The class includes forests that are a mix of native broadleaved trees and spontaneously established spruce and pine trees. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/313> .

# --- Children of 4.5 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.5.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.5.1" ;
    dcterms:identifier "451" ;
    skos:prefLabel "Transitional woodland/forest land"@en ;
    skos:definition "Forest land, including recently felled clear-cut, burnt, replanted or newly afforested. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.5> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/324> .

# --- Children of 4.6 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.6.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.6.1" ;
    dcterms:identifier "461" ;
    skos:prefLabel "Monoculture or mixed plantations"@en ;
    skos:definition "Monoculture or mixed plantations of non-native tree species with very sparse or lacking undergrowth, e.g. Eucalyptus plantations. Forest stands of single or mixed species consisting of native and/or non-native trees species that have long been established in European ecosystems and have diverse undergrowth typical for forest ecosystems should be classified as part of types 4.1 to 4.4. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.6> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/313> ,
                    <https://eunis.eea.europa.eu/habitats/22351> .

# =========================================================================
# MACRO-ECOSYSTEM 5: Heathland and shrub
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5" ;
    dcterms:identifier "5" ;
    skos:prefLabel "Heathland and shrub"@en ;
    skos:definition "Heathland and shrub are areas with vegetation dominated by shrubs or dwarf shrubs, which may include dispersed trees with a canopy cover below 30%. They include natural ecosystems of predominantly harsh conditions as well as secondary ecosystems created by extensive human use. The class includes heathlands and sclerophyllous vegetation."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.1" ;
    dcterms:identifier "51" ;
    skos:prefLabel "Tundra"@en ;
    skos:definition "Vegetated land with graminoids, shrubs, mosses or macro lichens overlying permafrost. European tundras are limited to Spitzbergen and northern Russia. Vegetation with the same species also occurs on boreal mountains and in the low arctic remote from the main permafrost region, notably in Fennoscandia and Iceland; these oroboreal and low arctic habitats are listed under alpine and subalpine grassland or arctic, alpine and subalpine shrub."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/T6.3> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.1.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.2" ;
    dcterms:identifier "52" ;
    skos:prefLabel "Scrub and heathland"@en ;
    skos:definition "Vegetation with low and closed cover, dominated by bushes, shrubs, dwarf shrubs (heather, briars, broom, gorse, laburnum etc.) and herbaceous plants, including semi-natural/successional stages and mature stages of development. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/322> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T3.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T3.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.3" ;
    dcterms:identifier "53" ;
    skos:prefLabel "Sclerophyllous vegetation"@en ;
    skos:definition "Bushy sclerophyllous vegetation including semi-natural/successional stages and mature stages of development; including maquis, matorral and garrigue. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/323> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T3.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.4> .


# --- LEVEL 3 ---

# --- Children of 5.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.1.1" ;
    dcterms:identifier "511" ;
    skos:prefLabel "Tundra"@en ;
    skos:definition "Vegetated land with graminoids, shrubs, mosses or macrolichens overlying permafrost. European tundras are limited to Spitzbergen and northern Russia. Vegetation with the same species also occurs on boreal mountains and in the low arctic remote from the main permafrost region, notably in Fennoscandia and Iceland; these oroboreal and low arctic habitats are listed under alpine and subalpine grassland or arctic, alpine and subalpine shrub."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F1> .

# --- Children of 5.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.2.1" ;
    dcterms:identifier "521" ;
    skos:prefLabel "Arctic, alpine and subalpine scrub"@en ;
    skos:definition "Shrub occurring north of or above the climatic tree limit, but outside the permafrost zone. Shrub occurring close to but below the climatic tree limit, where trees are suppressed either by late-lying snow or by wind or repeated browsing."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.2.2" ;
    dcterms:identifier "522" ;
    skos:prefLabel "Temperate and Mediterranean montane scrub"@en ;
    skos:definition "These scrub communities include deciduous and evergreen shrubs of the nemoral zone, and deciduous shrubs of the sub-mediterranean and supra-mediterranean zones that are adapted to a cooler climate. Excluded are heathlands with dominant Ericaceae, and the typically mediterranean maquis, garrigue and phrygana. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.2.3" ;
    dcterms:identifier "523" ;
    skos:prefLabel "Temperate shrub heathland"@en ;
    skos:definition "Shrub communities adapted to a cooler climate in which Ericaceae are dominant or at least prominent. Such heaths are best developed on acid soils in the Atlantic zone and also in sub-Atlantic Europe. This includes semi-natural (in the sense of substitutional /secondary) heathlands and scrub types. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/324> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F4> .

# --- Children of 5.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.3.1" ;
    dcterms:identifier "531" ;
    skos:prefLabel "Maquis, arborescent matorral and thermo-Mediterranean scrub"@en ;
    skos:definition "Evergreen sclerophyllous or lauriphyllous shrub vegetation, with a closed or nearly closed canopy structure, having nearly 100% cover of shrubs, with few annuals and some vernal geophytes; trees are nearly always present, some of which may be in shrub form. Shrubs, sometimes tall, of Juniperus, Arbutus, Cistus, Cytisus, Erica, Genista, Lavandula, Myrtus, Phillyrea, Pistacia, Quercus and Spartium are typical. Included is pseudomaquis, in which the dominants are mixed deciduous and evergreen shrubs. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F5> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.3.2" ;
    dcterms:identifier "532" ;
    skos:prefLabel "Garrigue"@en ;
    skos:definition "Evergreen sclerophyllous or lauriphyllous shrub vegetation, with an open canopy structure and some bare ground, usually with many winter annuals and vernal geophytes. Low shrubs of Cistus, Lavandula, Rosmarinus and Stoechas are usually present, and there may be some larger shrubs and scattered trees. Garrigue is found mostly in the Mediterranean, Macaronesian and Pontic regions, where it typically derives from degradation or regrowth of broadleaved evergreen forests, but it extends into deciduous forest areas in the supra-Mediterranean zone and sub-Mediterranean zones and into steppe areas in Anatolia. Includes shrubby land with mainly herbaceous vegetation and a large component of unpalatable non-vernal monocots (Asphodelus, Urginea) and thistles, provided that shrub cover exceeds 10%. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/324> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F6> ;
    skos:scopeNote "Includes semi-natural (substitutional/secondary) heathlands, shrub types and bushy sclerophyllous vegetation from CORINE class 3.2.4."@en .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.3.3" ;
    dcterms:identifier "533" ;
    skos:prefLabel "Spiny Mediterranean heaths (phrygana, hedgehog-heaths & coastal cliff vegetation)"@en ;
    skos:definition "Shrubland with dominant low spiny shrubs, widespread in Mediterranean and Anatolian regions with a summer-dry climate, occurring from sea level to high altitudes on dry mountains. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F7> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "5.3.4" ;
    dcterms:identifier "534" ;
    skos:prefLabel "Thermo-Atlantic xerophytic shrub (Madeira and Canary Islands)"@en ;
    skos:definition "Xerophytic shrub formations of the lower slopes of the Canary Islands and Madeira, rich in succulents, in particular cactiform or dendroid spurges Euphorbia spp., rosette-forming Aeonium spp. and composites. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/5.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/F8> .

# =========================================================================
# MACRO-ECOSYSTEM 6: Sparsely vegetated ecosystems
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6" ;
    dcterms:identifier "6" ;
    skos:prefLabel "Sparsely vegetated ecosystems"@en ;
    skos:definition "Sparsely or unvegetated ecosystems have a low density of vegetation, with typically at least 70% of barren soil. They include degraded sparsely or degraded non-vegetated areas as well as ecosystems under extreme natural conditions which may be traditionally grazed. They include bare rocks, glaciers, inland dunes and sand plains. In spite of low vegetation density, the ecosystems may contain high biodiversity of species adapted to an extreme environment."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.3> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.1" ;
    dcterms:identifier "61" ;
    skos:prefLabel "Bare rocks"@en ;
    skos:definition "Scree, cliffs, rock outcrops, including areas of active erosion, rocks and reef flats outside marine influence, inland salt planes. At least 90% of area of the ecosystem asset is covered by rocks. Rocks within a zone up to 100m from the high-water mark can be classified as coastal ecosystems."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/332> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T3.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T6.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.2" ;
    dcterms:identifier "62" ;
    skos:prefLabel "Semi-desert, desert and other sparsely vegetated areas"@en ;
    skos:definition "Non-coastal habitats with less than 30% vegetation cover (other than in crevices of rocks, screes or cliffs) which are characterised by very low water availability. They include areas which are sparsely vegetated due to land degradation."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/333> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T5.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.3" ;
    dcterms:identifier "63" ;
    skos:prefLabel "Ice sheets, glaciers and perennial snowfields"@en ;
    skos:definition "High mountain zones and high latitude land masses occupied by glaciers or by perennial snow. They may be inhabited by algae and invertebrates."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/335> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/T6.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.3.1> .


# --- LEVEL 3 ---

# --- Children of 6.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.1.1" ;
    dcterms:identifier "611" ;
    skos:prefLabel "Rocky pavements, outcrops, and screes"@en ;
    skos:definition "Accumulations of boulders, stones, rock fragments, pebbles, gravels or finer material, of non-aeolian depositional origin, unvegetated, occupied by lichens or mosses, or colonized by sparse herbs or shrubs. Included are screes and scree slopes produced by slope processes, moraines and drumlins originating from glacial deposition, sandar, eskers and kames resulting from fluvio-glacial deposition, block slopes, block streams and block fields constructed by periglacial depositional processes of downslope mass movement, ancient beach deposits constituted by former coastal constructional processes. Also including unvegetated, sparsely vegetated, and bryophyte- or lichen-vegetated cliffs, rock faces and rock pavements, not presently adjacent to the sea, and not resulting from recent volcanic activity."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/H2> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/H3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.1.2" ;
    dcterms:identifier "612" ;
    skos:prefLabel "Lava flows"@en ;
    skos:definition "Hard rock surfaces, rock jumbles, loose material deposits, soils, water bodies resulting from recent or present volcanic activity, unvegetated, occupied by lichens or mosses, or colonized by specialised, relatively sparse herb- or shrub-dominated communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/H6> .

# --- Children of 6.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.2.1" ;
    dcterms:identifier "621" ;
    skos:prefLabel "Semi-desert steppes"@en ;
    skos:definition "These mixed semi-deserts are dominated by suffrutescent (i.e. with a woody base) or sub-succulent (semi-fleshy) perennial shrubs and tussock grasses. Productivity and biomass are limited by low to very low average precipitation, extreme temperatures and, to a lesser extent, soil nutrients, but vary temporally in response to water availability. Vegetation takes a range of structural forms, including open shrublands, mixed shrublands with a tussock grass matrix, prairie-like tall forb grasslands, and very low dwarf shrubs interspersed with forbs or grasses. Total cover varies from 10% to 30% and the balance between shrubs and grasses is mediated by rainfall, herbivory and soil fertility. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/T5.1> . # IUCN GET T5.1

<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.2.2" ;
    dcterms:identifier "622" ;
    skos:prefLabel "Cool deserts and semi-desert steppes"@en ;
    skos:definition "Arid systems where productivity is limited by both low precipitation and cold temperatures but varies spatially in response to soil texture, salinity, and water table depth. Vegetation cover varies with soil conditions from near zero (on extensive areas of heavily salinized soils or mobile dunes) to >50% in upland grasslands and shrublands but is generally low in stature (less than 1 m tall). The dominant plants are perennial C3 grasses and xeromorphic suffrutescent or non-sclerophyllous perennial shrubs. Dwarf shrubs, tending to prostrate or cushion forms occur in areas exposed to strong, cold winds. Plant growth occurs mainly during warming spring temperatures after winter soil moisture recharges. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/T5.4> . # IUCN GET T5.4

<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.2.3" ;
    dcterms:identifier "623" ;
    skos:prefLabel "Other sparsely vegetated areas"@en ;
    skos:definition "Miscellaneous bare habitats, including glacial moraines, freeze-thaw features, inland sand dunes and trampled areas. Vegetation, if present, is dominated by algae, lichens or bryophytes, with vascular plants absent or very sparse. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/H5> .

# --- Children of 6.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/6.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "6.3.1" ;
    dcterms:identifier "631" ;
    skos:prefLabel "Ice sheets, glaciers and perennial snowfields"@en ;
    skos:definition "High mountain zones and high latitude land masses occupied by glaciers or by perennial snow. They may be inhabited by algae and invertebrates."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/6.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/H4> .

# =========================================================================
# MACRO-ECOSYSTEM 7: Inland wetlands
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/7> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7" ;
    dcterms:identifier "7" ;
    skos:prefLabel "Inland wetlands"@en ;
    skos:definition "Inland wetlands are areas that are year-round or seasonally strongly affected by water, in the form of temporary flooding or groundwater levels close to surface. This class includes natural, semi-natural or modified inland marshes as well as mires, bogs and fens, but excludes seasonally flooded grasslands and heathlands, for example. It also includes peat extraction sites."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.1" ;
    dcterms:identifier "71" ;
    skos:prefLabel "Inland marshes and other wetlands on mineral soil"@en ;
    skos:definition "Low-lying land usually flooded in winter, and more or less saturated by water all year round. Vegetation is composed mainly of rushes, sedges, and some reed and shrub. Other types of this class include reedbeds and springs."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/411> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/TF1.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/TF1.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.4> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2" ;
    dcterms:identifier "72" ;
    skos:prefLabel "Mires, bogs and fens"@en ;
    skos:definition "Wetlands, with the water table at or above ground level for at least half of the year, dominated by mosses, herbaceous or ericoid vegetation. Includes inland saltmarshes and waterlogged habitats where the groundwater is frozen. Excludes the water body and rock structure of springs and waterlogged habitats dominated by trees or large shrubs. Includes bog degradation stages dominated by heathland but excludes wet heathlands on mineral soils which support limited peat formation. Includes peat extraction sites. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/412> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/TF1.6> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/TF1.7> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.6> .


# --- LEVEL 3 ---

# --- Children of 7.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.1.1" ;
    dcterms:identifier "711" ;
    skos:prefLabel "Inland marshes"@en ;
    skos:definition "Low-lying land usually flooded in winter, and more or less saturated by water all year round. Vegetation is composed mainly of rushes, sedges, and some reed and shrub."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C3.1> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C3.2> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C3.3> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D5.1> ,
                    <https://eunis.eea.europa.eu/habitats/274> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D5.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.1.2" ;
    dcterms:identifier "712" ;
    skos:prefLabel "Inland salt marshes"@en ;
    skos:definition "Salt meadows and swards of Salicornia and other Chenopodiaceae of inland salt basins of the nemoral zone. Inland saltmarshes of middle Europe are remarkable, extremely threatened communities occurring in a few isolated locations."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D6.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.1.3" ;
    dcterms:identifier "713" ;
    skos:prefLabel "Reedbeds"@en ;
    skos:definition "Water-fringing stands of tall vegetation by lakes (including brackish lakes), rivers and brooks, usually species-poor and often dominated by one species. Mainly composed of Common reed, horsetail and tall sedges. Including Mediterranean beds of tall canes lining permanent or temporary water courses and water bodies."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.1.4" ;
    dcterms:identifier "714" ;
    skos:prefLabel "Springs"@en ;
    skos:definition "Springs are formed where groundwater flows onto the surface and have various ecological expressions, depending on terrain and water characteristics. They are an important and threatened aquatic habitat."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.1> .

# --- Children of 7.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2.1" ;
    dcterms:identifier "721" ;
    skos:prefLabel "Raised bogs"@en ;
    skos:definition "The mire surface and underlying peat of highly oligotrophic, strongly acidic peatlands with a raised centre from which water drains towards the edges. The peat is composed mainly of sphagnum remains. Raised bogs form on nearly flat ground and derive moisture and nutrients only from rainfall (ombrotrophic). Raised bog complexes (X04) include larger bog pools and a marginal lagg, as well as the main mire surface, which in actively-growing raised bogs typically comprises a complex of low hummocks, small pools and their associated vegetation. Raised bogs form only in cool climates with high rainfall. Most of the species that bogs harbour are rare and their populations fragmented into isolated relictual elements; several are threatened. The remaining intact or nearly intact communities are exceptional."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D1.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2.2" ;
    dcterms:identifier "722" ;
    skos:prefLabel "Blanket bogs"@en ;
    skos:definition "Mire surface and underlying peat of ombrotrophic peatlands, formed on flat or gently sloping ground with poor surface drainage, in oceanic climates with high rainfall. The mire surface may on flatter ground be very similar to that of a raised bog, with a complex of small pools and terrestrial hummocks. In the strictest sense, blanket bogs are a habitat endemic to northwestern Europe, characteristic of the western and northern British Isles, the Faeroe Islands and the western seaboard of Scandinavia. They often cover extensive areas with local topographic features supporting distinct communities. Sphagna (Sphagnum spp) play an important role in all of them, accompanied by Narthecium ossifragum, Molinia caerulea, Scirpus cespitosus, Schoenus nigricans, Eriophorum angustifolium, Eriophorum vaginatum and Calluna vulgaris. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D1.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2.3" ;
    dcterms:identifier "723" ;
    skos:prefLabel "Valley mires, poor fens and transition mires"@en ;
    skos:definition "Weakly to strongly acid peatlands, flushes and vegetated rafts formed in situations where they receive water from the surrounding landscape or are intermediate between land and water. Included are quaking bogs and vegetated non-calcareous springs. Excluded are calcareous fens, and reedbeds. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2.4" ;
    dcterms:identifier "724" ;
    skos:prefLabel "Aapa, palsa and polygon mires"@en ;
    skos:definition "Patterned mire complexes of the arctic, subarctic and northern boreal zones. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2.5" ;
    dcterms:identifier "725" ;
    skos:prefLabel "Base-rich fens and calcareous spring mires"@en ;
    skos:definition "Peatlands, flushes and vegetated springs with calcareous or eutrophic ground water, within river valleys, alluvial plains, or on hillsides. As in poor fens, the water level is at or near the surface of the substratum and peat formation depends on a permanently high-water table. Excluded are reedbeds."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/D4> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "7.2.6" ;
    dcterms:identifier "726" ;
    skos:prefLabel "Peat extraction sites"@en ;
    skos:definition "Peatland areas where peat is being mined or have been mined and natural conditions and vegetation have not (been) restored yet. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/7.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/412> .

# =========================================================================
# MACRO-ECOSYSTEM 8: Rivers and canals
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/8> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8" ;
    dcterms:identifier "8" ;
    skos:prefLabel "Rivers and canals"@en ;
    skos:definition "Permanent freshwater inland surface waters of linear character. These include natural water courses, such as rivers, streams etc., as well as anthropogenic structures built for transportation, drainage or water supply purposes, i.e., canals, ditches etc."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8.1" ;
    dcterms:identifier "81" ;
    skos:prefLabel "Rivers and streams"@en ;
    skos:definition "Natural watercourses, such as rivers, streams etc. (even though often modified by man) serving as water drainage channels."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/8> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/511> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F1.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F1.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F1.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F1.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F1.5> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F1.7> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8.2" ;
    dcterms:identifier "82" ;
    skos:prefLabel "Canals, ditches and drains"@en ;
    skos:definition "Artificial watercourses serving as water drainage or transport channels."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/8> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/511> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/F3.5> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2.2> .


# --- LEVEL 3 ---

# --- Children of 8.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8.1.1" ;
    dcterms:identifier "811" ;
    skos:prefLabel "Permanent, non-tidal, fast, turbulent water courses"@en ;
    skos:definition "Permanent water courses with fast-flowing turbulent water and their associated animal and microscopic algal pelagic and benthic communities. Rivers, streams, brooks, rivulets, rills, torrents, waterfalls, cascades and rapids are included. The bed is typically composed of rocks, stones or gravel with only occasional sandy and silty patches. Includes high, mid and low-altitude, usually small to medium-sized streams as defined by the Water Framework Directive. Various ecological sub-types exist, depending on the surrounding geology, climate, altitude etc."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C2.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8.1.2" ;
    dcterms:identifier "812" ;
    skos:prefLabel "Permanent non-tidal, smooth-flowing watercourses"@en ;
    skos:definition "Permanent water courses with non-turbulent water and their associated animal and microscopic algal pelagic and benthic communities. Slow-flowing rivers, streams, brooks, rivulets and rills; also fast-flowing rivers with laminar flow. The bed is typically composed of sand or mud. Includes mid and low-altitude streams as defined by the Water Framework Directive. Various ecological sub-types exist, depending on the surrounding geology, climate, land use etc."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C2.3> .

# --- Children of 8.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8.2.1" ;
    dcterms:identifier "821" ;
    skos:prefLabel "Canals"@en ;
    skos:definition "Canals are substantial human-made linear water bodies that were created for the purpose of enabling transport by ship in most cases. They are heavily modified water bodies but may have a range of ecological features, in particular if they are no longer in active shipping use and hence subject to maintenance works."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "8.2.2" ;
    dcterms:identifier "822" ;
    skos:prefLabel "Ditches and drains"@en ;
    skos:definition "Ditches and drains are small human-made linear water bodies that were created for drainage purposes in most cases. Some ditches have been developed from pre-existing brooks or small streams. Both types are heavily modified water bodies but may have a range of ecological features."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/8.2> .

# =========================================================================
# MACRO-ECOSYSTEM 9: Lakes and reservoirs
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/9> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9" ;
    dcterms:identifier "9" ;
    skos:prefLabel "Lakes and reservoirs"@en ;
    skos:definition "Permanent freshwater inland surface waters composed of primarily non-linear water bodies. These include natural water bodies (lakes) as well as anthropogenic water bodies developed mainly for water supply or energy generation purposes."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.3> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.1" ;
    dcterms:identifier "91" ;
    skos:prefLabel "Lakes and ponds"@en ;
    skos:definition "Natural (but sometimes modified) water bodies with presence of standing water surface during the entire year (except in very dry years for some types)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/512> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.5> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.6> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.7> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.10> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F3.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.2" ;
    dcterms:identifier "92" ;
    skos:prefLabel "Artificial reservoirs"@en ;
    skos:definition "Artificial water bodies with presence of standing water surface during most of the year. Developed mainly for water supply or energy generation purposes."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/512> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F3.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F3.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.3" ;
    dcterms:identifier "93" ;
    skos:prefLabel "Geothermal pools and wetlands (Iceland)"@en ;
    skos:definition "Hot springs, geysers, mud pots and associated wetlands resulting from interactions of deeply circulating groundwater with magma and hot rocks."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.9> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.3.1> .


# --- LEVEL 3 ---

# --- Children of 9.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.1.1" ;
    dcterms:identifier "911" ;
    skos:prefLabel "Lakes"@en ;
    skos:definition "Lakes of natural origin containing fresh water. Manmade freshwater bodies (e.g. by damming a river) can be included, provided that they contain seminatural aquatic communities of lake character. Many ecological sub-types exist which can be distinguished on the basis of underlying geology, altitude, climate and/or their aquatic communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.1.2" ;
    dcterms:identifier "912" ;
    skos:prefLabel "Inland saline or brackish lakes and pools"@en ;
    skos:definition "Lakes and pools of natural origin containing brackish or salt water. Often found in summer-dry climates with low precipitation; many types are prone to drying out temporarily. Characteristic feature is their saline or brackish water which determines the composition of vegetation and other aquatic communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.1.3" ;
    dcterms:identifier "913" ;
    skos:prefLabel "Ponds and natural small standing water bodies"@en ;
    skos:definition "Ponds and other small standing water bodies containing fresh water. These can hold water all year round or may be temporarily without water during dry periods. Includes various types, ranging from natural pools, small lakes to man-made ponds with natural features. Many ecological sub-types exist which can be distinguished on the basis of underlying geology, altitude, climate and/or their aquatic communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.1> .

# --- Children of 9.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.2.1" ;
    dcterms:identifier "921" ;
    skos:prefLabel "Artificial reservoirs"@en ;
    skos:definition "Artificial water bodies that have been created by human action, e.g. by damming a river valley or by lining a natural depression with concrete or a similar surface to prevent water leakage. Developed mainly for water supply or energy generation purposes. Can be very large water bodies but also includes smaller bodies (e.g. at farm level for irrigation) if they are of artificial character."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.2> .

# --- Children of 9.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/9.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "9.3.1" ;
    dcterms:identifier "931" ;
    skos:prefLabel "Geothermal pools and wetlands (Iceland)"@en ;
    skos:definition "Hot springs, geysers, mud pots and associated wetlands result from interactions of deeply circulating groundwater with magma and hot rocks that produce chemically precipitated substrates. They support a specialised but low-diversity biota structured by extreme thermal and geochemical gradients."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/9.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/F2.9> . # IUCN GET F2.9

# =========================================================================
# MACRO-ECOSYSTEM 10: Marine inlets and transitional waters
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/10> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10" ;
    dcterms:identifier "10" ;
    skos:prefLabel "Marine inlets and transitional waters"@en ;
    skos:definition "Marine inlets and transitional waters are ecosystems on the land-water interface under the influence of tides and with salinity higher than 0.5 ‰. They include lagoons, estuaries and other transitional waters."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.3> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/10.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10.1" ;
    dcterms:identifier "101" ;
    skos:prefLabel "Coastal lagoons"@en ;
    skos:definition "Stretches of salt or brackish water in coastal areas which are separated from the sea by a tongue of land or other similar topography. These water bodies can be connected to the sea at limited points, either permanently or for parts of the year."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/10> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/521> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/FM1.3> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.1.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/10.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10.2" ;
    dcterms:identifier "102" ;
    skos:prefLabel "Estuaries and bays"@en ;
    skos:definition "This class includes two main types: a) estuaries, i.e., the mouth of a river under tidal influence within which the tide ebbs and flows. b) bays, i.e., a coastal body of water partly enclosed by land and that directly connects to a larger main body of water, in particular a sea or ocean. Vegetation, and fauna is adapted to saline and/or brackish conditions. It is recommended to align the border between marine waters, estuaries and river mouths in agreement with Marine Strategy Framework Directive reporting."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/10> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/522> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/FM1.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/10.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10.3" ;
    dcterms:identifier "103" ;
    skos:prefLabel "Intertidal flats"@en ;
    skos:definition "Coastal zone under tidal influence between open sea and land, which is flooded by sea water regularly twice a day in a ca. 12 hours cycle. Defined by the area between the average lowest and highest sea water level at low tide and high tide. Generally non-vegetated expanses of mud, sand or rock lying between high and low water marks."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/10> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/423> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.3.1> .


# --- LEVEL 3 ---

# --- Children of 10.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/10.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10.1.1" ;
    dcterms:identifier "1011" ;
    skos:prefLabel "Coastal lagoons"@en ;
    skos:definition "Coastal brackish, saline or hypersaline lakes, ponds or pools and their pelagic vertebrates and plankton."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/C1.5> .

# --- Children of 10.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/10.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10.2.1" ;
    dcterms:identifier "1021" ;
    skos:prefLabel "Estuaries and bays"@en ;
    skos:definition "This class includes two types: a) Estuaries, i.e. the mouth of a river under tidal influence within which the tide ebbs and flows; b) Bays, i.e. coastal body of water partly enclosed by land and that directly connects to a larger main body of water, in particular a sea or ocean. In both cases the vegetation and fauna is adapted to saline and/or brackish conditions."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/522> .

# --- Children of 10.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/10.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "10.3.1" ;
    dcterms:identifier "1031" ;
    skos:prefLabel "Intertidal flats (e.g., Wadden Sea)"@en ;
    skos:definition "Coastal zone under tidal influence between open sea and land, which is flooded by sea water regularly twice a day in a ca. 12 hours cycle. Found in the area between the average lowest and highest sea water level at low tide and high tide. Generally non-vegetated expanses of mud, sand or rock lying between high and low water marks though free-floating macrophytes may occur (e.g. Ulva, Enteromorpha etc.)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/10.3> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/423> .

# =========================================================================
# MACRO-ECOSYSTEM 11: Coastal beaches, dunes and wetlands
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/11> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11" ;
    dcterms:identifier "11" ;
    skos:prefLabel "Coastal beaches, dunes and wetlands"@en ;
    skos:definition "The class coastal areas refers to land-based ecosystems close to the sea, with marine influences, such as salt spray and saline groundwater, and that may be flooded during high tide or extreme events. The class includes beaches, dunes (which may include wetland areas below the MMU in between rows of dunes) and coastal saltmarshes and salines."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.1" ;
    dcterms:identifier "111" ;
    skos:prefLabel "Artificial shorelines"@en ;
    skos:definition "Man-made dykes and dams, including wave breakers extending into the sea, constructed primarily to protect land from seawater."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT3.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.1.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.2" ;
    dcterms:identifier "112" ;
    skos:prefLabel "Coastal dunes, beaches and sandy and muddy shores"@en ;
    skos:definition "Natural non-vegetated expanses of sand or pebble/gravel, in coastal locations, like beaches, dunes, gravel pads, muddy shores. Including salt-influenced wetlands between rows of dunes."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/331> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT2.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.3" ;
    dcterms:identifier "113" ;
    skos:prefLabel "Rocky shores"@en ;
    skos:definition "Scree, cliffs, rock outcrops, including areas of active erosion, rocks and reef flats situated above the high-water mark up to a distance of 100 m away from the high water mark."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/332> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT1.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.4" ;
    dcterms:identifier "114" ;
    skos:prefLabel "Coastal saltmarshes and salines"@en ;
    skos:definition "This class includes two main types: a) Coastal saltmarshes, which are vegetated low-lying areas in the coastal zone, mostly above the high-tide line, but always susceptible to flooding by seawater. b) Salt-pans for extraction of salt from salt water by evaporation, under active use or in process of abandonment."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/421> ,
                    <http://dd.eionet.europa.eu/vocabulary/landcover/clc/422> ,
                    <https://global-ecosystems.org/explore/groups/MFT1.3> ,
                    <https://global-ecosystems.org/explore/groups/F2.6> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4.2> .


# --- LEVEL 3 ---

# --- Children of 11.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.1.1" ;
    dcterms:identifier "1111" ;
    skos:prefLabel "Artificial shorelines"@en ;
    skos:definition "Man-made dykes and dams, including wave breakers extending into the sea, constructed primarily to protect land from seawater, but sometimes also used for roads. Deposited or dumped artificial structures in the coast may attract marine biota that would not otherwise occupy such locations. Excludes transport infrastructure on the shore such as ports and seaside promenades that should be recorded in settlements and other artificial areas."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.1> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/MT3.1> .

# --- Children of 11.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.2.1" ;
    dcterms:identifier "1121" ;
    skos:prefLabel "Coastal dunes"@en ;
    skos:definition "Dunes occur in sand-covered shorelines of the oceans, their connected seas and associated coastal lagoons, fashioned by the action of wind or waves. Dunes are formed by aeolian deposits, though sometimes re-fashioned by waves. Dunes may be covered by grasses or forests, though generally there are important areas of bare soil. Vegetation is dominated by salt- and drought-tolerant species."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/B1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.2.2" ;
    dcterms:identifier "1122" ;
    skos:prefLabel "Beaches and sandy shores"@en ;
    skos:definition "Sandy shorelines include beaches, sand bars and spits, located just above the main waterline. These systems are affected by wave action and typically lack macrophytes, with their low productivity largely underpinned by detrital subsidies dominated by wrack (i.e. drift seaweed accumulating at the high-water mark) and phytoplankton, particularly in the surf zone of dissipative beaches. Beaches include gently sloping beaches and beach-ridges, formed by sands brought by waves, longshore drift and storm waves."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/B1> ,
                  <https://global-ecosystems.org/explore/biomes/MT1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.2.3" ;
    dcterms:identifier "1123" ;
    skos:prefLabel "Muddy shores"@en ;
    skos:definition "Highly productive environments at and above the main waterline defined by their fine particle size (dominated by silts). Benthic diatoms are the key primary producer. Macrophytes are generally absent in the intertidal zone. Fauna are dominated by deposit-feeding taxa (consuming organic matter that accumulates in the fine-grained sediments) and detritivores feeding on wrack (i.e. drift algae deposited at the high-water mark) and other sources of macro-detritus. Bioturbating and tube-dwelling taxa are key ecosystem engineers."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/B1> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/MT1.2> .

# --- Children of 11.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.3.1" ;
    dcterms:identifier "1131" ;
    skos:prefLabel "Coastal shingle"@en ;
    skos:definition "Beaches of the oceans, of their connected seas and of their associated coastal lagoons, covered by pebbles, or sometimes boulders, usually formed by wave action."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/B2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.3.2" ;
    dcterms:identifier "1132" ;
    skos:prefLabel "Rock cliffs, ledges and shores"@en ;
    skos:definition "Rock exposures adjacent to the oceans, their connected seas and associated coastal lagoons, or separated from them by a narrow shoreline. The faces, ledges and caves of sea-cliffs and the expanses of rocky shore are important as reproduction, resting and feeding sites for seabirds, sea-mammals and a few groups of terrestrial birds. Sea-cliffs may also harbour highly distinctive, specialised salt-tolerant vegetation with associated terrestrial fauna."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/B3> .

# --- Children of 11.4 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.4.1" ;
    dcterms:identifier "1141" ;
    skos:prefLabel "Coastal saltmarshes"@en ;
    skos:definition "Vegetated area in the coastal zone, dominated by Angiosperms, mostly above the high-tide line but always susceptible to flooding by seawater. Often in the process of being filled in by coastal mud and sand sediments. The vegetation develops on a variety of sandy and muddy sediment types and may have admixtures of coarser material. The character of the saltmarsh communities is affected by height up the shore, resulting in a zonation pattern related to the degree or frequency of immersion in seawater."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A2.5> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "11.4.2" ;
    dcterms:identifier "1142" ;
    skos:prefLabel "Salines"@en ;
    skos:definition "Salt-pans for extraction of salt from salt water by evaporation, active or in process of abandonment."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/11.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A2.5> .

# =========================================================================
# MACRO-ECOSYSTEM 12: Marine ecosystems (coastal waters, shelf and open ocean)
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12" ;
    dcterms:identifier "12" ;
    skos:prefLabel "Marine ecosystems"@en ;
    skos:scopeNote "Coastal waters, shelf and open ocean"@en ;
    skos:definition "Marine ecosystems include all marine areas in the sea extent at low tide level or below mean sea level. This ranges from near-shore ecosystems to deep water marine ecosystems. Aligned with accounting principles, the ecosystem includes the whole water column including the seabed and the pelagic zone."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.7> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.8> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.9> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.10> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.1" ;
    dcterms:identifier "121" ;
    skos:prefLabel "Marine macrophyte habitats"@en ;
    skos:definition "Kelp forests, seaweeds and seagrasses."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.2" ;
    dcterms:identifier "122" ;
    skos:prefLabel "Coral reefs"@en ;
    skos:definition "Coral reef communities developing in a range of habitats from exposed open coasts to estuaries, marine inlets and deeper offshore habitats."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.5> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.2.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.3" ;
    dcterms:identifier "123" ;
    skos:prefLabel "Worm reefs"@en ;
    skos:definition "Sublittoral reefs of polychaete worms in mixed sediments found in a variety of hydrographic conditions."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.5> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.3.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.4" ;
    dcterms:identifier "124" ;
    skos:prefLabel "Shellfish beds and reefs"@en ;
    skos:definition "Sublittoral mussel beds comprised of either the horse mussel Modiolus modiolus or the common mussel Mytilus edulis."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.4> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.4.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.5" ;
    dcterms:identifier "125" ;
    skos:prefLabel "Subtidal sand beds and mud plains"@en ;
    skos:definition "Clean medium to fine sands or non-cohesive slightly muddy sands and sublittoral mud extending from the extreme lower shore to offshore habitats."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.7> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M1.8> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.5.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.6" ;
    dcterms:identifier "126" ;
    skos:prefLabel "Subtidal rocky substrates"@en ;
    skos:definition "Infralittoral rock habitats of bedrock, boulders and cobbles occurring in the shallow subtidal zone."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/M1.6> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.6.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.7> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.7" ;
    dcterms:identifier "127" ;
    skos:prefLabel "Continental and island slopes"@en ;
    skos:definition "Habitats on the deep-sea bed with significant elevation in relation to their surroundings."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/M3.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.7.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.8> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.8" ;
    dcterms:identifier "128" ;
    skos:prefLabel "Deepwater benthic and pelagic ecosystems"@en ;
    skos:definition "The area of the sea beyond the continental shelf break, including the seabed and the pelagic water column."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M2.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M2.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M2.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M2.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M3.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M3.3> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M3.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M3.5> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M3.6> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/M3.7> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.8.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.9> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.9" ;
    dcterms:identifier "129" ;
    skos:prefLabel "Deepwater coastal inlets (fjords)"@en ;
    skos:definition "Semi-confined aquatic systems with many features of open oceans, showing strong environmental and biotic gradients."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/FM1.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.9.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.10> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.10" ;
    dcterms:identifier "1210" ;
    skos:prefLabel "Sea ice"@en ;
    skos:definition "Ice formations floating on sea water, variable in form and structure, unstable and dynamic."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12> ;
    skos:exactMatch <https://global-ecosystems.org/explore/groups/M2.5> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.10.1> .


# --- LEVEL 3 ---

# --- Children of 12.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.1.1" ;
    dcterms:identifier "1211" ;
    skos:prefLabel "Kelp forests"@en ;
    skos:definition "The shallow sublittoral seabed supports important seaweed communities where conditions are suitable in terms of substrate, water flow and turbidity. Kelp forest is found on rocky substrate of some size, e.g. boulders or bedrock. Kelp forests are important marine habitats that provide shelter to a wide range of fish and other aquatic animals. In exposed conditions the kelp is Laminaria hyperborea whilst in more sheltered habitats it is usually Laminaria saccharina; other kelp species may dominate under certain conditions."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.52> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.1.2" ;
    dcterms:identifier "1212" ;
    skos:prefLabel "Coastal macrophyte beds"@en ;
    skos:definition "Areas of mixed ground which lack stable rock as anker for kelp support seaweed communities. While such sublittoral sediments may include some kelp (Laminaria saccharina), they are characterised by bootlace weed Chorda filum and various red and brown seaweeds, particularly filamentous types. The generally sheltered nature of these habitats enables the seaweeds to grow on shells and small stones which lie on the sediment surface; some communities develop as loose-lying mats on the sediment surface."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.1.3" ;
    dcterms:identifier "1213" ;
    skos:prefLabel "Seagrass meadows"@en ;
    skos:definition "Beds of submerged marine angiosperms in the genera Cymodocea, Halophila, Posidonia, Ruppia, Thalassia, Zostera."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.1> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.53> .

# --- Children of 12.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.2.1" ;
    dcterms:identifier "1221" ;
    skos:prefLabel "Coral reefs"@en ;
    skos:definition "These communities develop in a range of habitats from exposed open coasts to estuaries, marine inlets and deeper offshore habitats and may be found in a variety of sediment types and salinity regimes. A major habitat type is formed by coral reefs of Lophelia pertusa; a cold water, reef-forming coral, which has a wide geographic distribution ranging from 55°S to 70°N, where water temperatures typically remain between 4-8°C. These reefs are generally subject to moderate current velocities (0.5 knots). The majority of records occur in the north-east Atlantic. The extent of L. pertusa reefs varies, with examples off Norway several km long and more than 20 m high. The Mediterranean Sea also harbours important coral reef communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.63> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A6.61> .

# --- Children of 12.3 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.3.1" ;
    dcterms:identifier "1231" ;
    skos:prefLabel "Worm reefs"@en ;
    skos:definition "Sublittoral reefs of polychaete worms in mixed sediments found in a variety of hydrographic conditions. Such habitats may range from extensive structures of considerable size to lose agglomerations of tubes. Such communities often play an important role in the structural composition or stability of the seabed and provide a wide range of niches for other species to inhabit. Consequently, polychaete worm reefs often support a diverse flora and fauna, for example Sabellaria spinosa which has gone from being widespread to red list species."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.3> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A4.22> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A4.232> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.61> .

# --- Children of 12.4 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.4.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.4.1" ;
    dcterms:identifier "1241" ;
    skos:prefLabel "Shellfish beds and reefs"@en ;
    skos:definition "Sublittoral mussel beds comprised of either the horse mussel Modiolus modiolus or the common mussel Mytilus edulis. These communities may be sublittoral extensions of littoral reefs or exist independently. Found in a variety of habitats ranging from sheltered estuaries and marine inlets to open coasts and offshore areas they may occupy a range of substrata, although due to the stabilising effect such communities have on the substratum muddy mixed sediments are typical. A diverse range of epibiota and infauna often exists in these communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.62> .

# --- Children of 12.5 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.5.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.5.1" ;
    dcterms:identifier "1251" ;
    skos:prefLabel "Subtidal sand beds and mud plains"@en ;
    skos:definition "Clean medium to fine sands or non-cohesive slightly muddy sands on open coasts, offshore or in estuaries and marine inlets. Such habitats are often subject to a degree of wave action or tidal currents which restrict the silt and clay content to less than 15%. This habitat is characterised by a range of taxa including polychaetes, bivalve molluscs and amphipod crustacea. Sublittoral mud and cohesive sandy mud extending from the extreme lower shore to offshore, circalittoral habitats. This biotope is predominantly found in sheltered harbours, sealochs, bays, marine inlets and estuaries and stable deeper/offshore areas where the reduced influence of wave action and/or tidal streams allow fine sediments to settle. Estuarine muds tend to be characterised by polychaetes and oligochaetes."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.5> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.2> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A5.3> .

# --- Children of 12.6 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.6.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.6.1" ;
    dcterms:identifier "1261" ;
    skos:prefLabel "Subtidal rocky substrates"@en ;
    skos:definition "Infralittoral rock includes habitats of bedrock, boulders and cobbles which occur in the shallow subtidal zone and typically support seaweed communities. The upper limit is marked by the top of the kelp zone whilst the lower limit is marked by the lower limit of kelp growth or the lower limit of dense seaweed growth. Infralittoral rock typically has an upper zone of dense kelp (forest) and a lower zone of sparse kelp (park), both with an understorey of erect seaweeds. In exposed conditions the kelp is Laminaria hyperborea whilst in more sheltered habitats it is usually Laminaria saccharina; other kelp species may dominate under certain conditions. Areas of mixed ground, lacking stable rock, may lack kelps but support seaweed communities. In estuaries and other turbid-water areas the shallow subtidal may be dominated by animal communities, with only poorly developed seaweed communities."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.6> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A3> .

# --- Children of 12.7 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.7.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.7.1" ;
    dcterms:identifier "1271" ;
    skos:prefLabel "Continental and island slopes"@en ;
    skos:definition "Habitats on the deep-sea bed with significant elevation (typically <200m deep) in relation to their surroundings. Includes permanently submerged flanks of oceanic islands, seamounts, knolls and banks, oceanic ridges, abyssal hills and carbonate mounds."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.7> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A6.7> .

# --- Children of 12.8 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.8.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.8.1" ;
    dcterms:identifier "1281" ;
    skos:prefLabel "Deepwater benthic and pelagic ecosystems"@en ;
    skos:definition "The area of the sea beyond the continental shelf break, including the seabed and the pelagic water column. The shelf break occurs at variable depth, but is generally over 200 m. The upper limit of the deep-sea zone is marked by the edge of the shelf. Includes areas of the Mediterranean Sea which are deeper than 200 m but not of the Baltic Sea which is a shelf sea. Excludes caves in the deep sea irrespective of depth.\nThree main components can be distinguished: the seabed and the water column divided into the photic zone (influenced by sunlight) and the water column below down to the seabed.\nThe seabed in particular harbours specialised deep water benthic habitats, for example reefs formed by 'Black and White smokers' found at the Atlantic ridge and listed in the EU Habitats Directive."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.8> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A6> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A7> .

# --- Children of 12.9 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.9.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.9.1" ;
    dcterms:identifier "1291" ;
    skos:prefLabel "Deepwater coastal inlets (fjords)"@en ;
    skos:definition "Deepwater coastal inlets (e.g. fjords, sea lochs) are semi-confined aquatic systems with many features of open oceans. Strong influences from adjacent freshwater and terrestrial systems produce striking environmental and biotic gradients. Autochthonous energy sources are dominant, but allochthonous sources (e.g. glacial ice discharge, freshwater streams and seasonal permafrost meltwater) may contribute 10% or more of particulate organic matter. Phytoplankton, notably diatoms, contribute most of the primary production, along with biofilms and macroalgae in the epibenthic layer. Seasonal variation in inflow, temperatures, ice cover and insolation drives pulses of in situ and imported productivity that generate blooms in diatoms, consumed in turn by jellyfish, micnekton, a hierarchy of fish predators and marine mammals."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.9> .

# --- Children of 12.10 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/12.10.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "12.10.1" ;
    dcterms:identifier "12101" ;
    skos:prefLabel "Sea ice"@en ;
    skos:definition "Ice formations floating on sea water, usually constituting an incomplete cover, variable in form and structure, unstable and dynamic under the influence of surface air and water currents."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/12.10> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/A8.1> .
