    skos:notation "2.6.2" ;
    dcterms:identifier "262" ;
    skos:prefLabel "Christmas tree plantations"@en ;
    skos:definition "Christmas tree plantations"@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/FB.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.6.3" ;
    dcterms:identifier "263" ;
    skos:prefLabel "Perennial bioenergy crops"@en ;
    skos:definition "This class has two expressions: a) Perennial energy grasses (e.g. Miscanthus, Reed canary grass) and other multi-annual crops used for oil or fibre production. b) Woodland treated as coppice without standards; plantations of dwarf trees or shrubs cultivated for wood or small-tree production, with a regular whole-plant harvesting regime, including short-rotation Salix beds for biomass production."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/1772> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/FB.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.6.4" ;
    dcterms:identifier "264" ;
    skos:prefLabel "Semi-natural elements associated with agricultural land use in other farmland"@en ;
    skos:definition "Traditional agricultural land use and landscape elements including hedges, ponds, grassy margins etc. as part of the farmed area. Such remaining semi-natural elements are considered part of cropland (and grassland) and can be mapped separately. Treelines and hedgerows are often easiest to distinguish. Member States are requested to fully document the type of landscape elements included in this class where it is reported separately."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6> .

# =========================================================================
# MACRO-ECOSYSTEM 3: Grassland
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3" ;
    dcterms:identifier "3" ;
    skos:prefLabel "Grassland"@en ;
    skos:scopeNote "Pastures, semi-natural and natural grasslands"@en ;
    skos:definition "Grassland covers areas dominated by herbaceous vegetation (including in particular grasses and forbs, but also mosses and lichens) of two kinds – modified grasslands (sown and used for grazing or hay and silage production) and (semi-)natural (extensively managed) grasslands. Grassland also includes some agroforestry area used for grazing, such as cork and holm oak stands or wooded pasture. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc. are considered part of this ecosystem type."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.1" ;
    dcterms:identifier "31" ;
    skos:prefLabel "Sown pastures and other grass (modified grasslands)"@en ;
    skos:definition "Stable grassland characterised by agricultural use or strong human disturbance. Floral composition dominated by Graminaceae and shaped by human activity. Regularly re-sown and fertilised and used for grazing or mechanical harvesting of grass. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/231> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2" ;
    dcterms:identifier "32" ;
    skos:prefLabel "Natural and semi-natural grasslands"@en ;
    skos:definition "Grasslands under no or moderate human influence. Mostly low productivity grasslands composed of native species adapted to the local environment. Can be under agro-forestry use. Often situated in areas of rough, uneven ground, steep slopes or wetter areas; frequently including rocky areas or patches of other (semi-)natural vegetation. Small semi-natural elements which are associated with agricultural land use, such as hedges, ponds, grassy margins etc., are considered part of this ecosystem type. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/321> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.5> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T4.5> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T6.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/MT2.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.7> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.8> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.9> .

# --- LEVEL 3 ---

# --- Children of 3.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.1.1" ;
    dcterms:identifier "311" ;
    skos:prefLabel "Sown pastures used for grazing"@en ;
    skos:definition "Stable eutrophic, grassland characterized by agricultural use or strong human disturbance. Floral composition dominated by Graminaceae and shaped by human activity. Regularly re-sown and fertilised and typically used for grazing."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/231> ;
    skos:scopeNote "Including EUNIS E1 (dry Grasslands) and E2 (Mesic Grasslands)"@en .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.1.2" ;
    dcterms:identifier "312" ;
    skos:prefLabel "Sown grassland mown frequently for fodder or silage"@en ;
    skos:definition "Sown grassland which is stable and mostly under intensive use, regularly re-sown and normally strongly fertilised. Under less intensive use it can include patches of lowland and montane mesotrophic grassland and hay meadows of the boreal, nemoral, warm-temperate humid and Mediterranean zones. All types are harvested mechanically for silage or hay."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.1.3" ;
    dcterms:identifier "313" ;
    skos:prefLabel "Semi-natural elements associated with agricultural land use in modified grassland"@en ;
    skos:definition "Traditional agricultural land use and landscape elements including hedges, ponds, grassy margins etc. as part of the farmed area. Such remaining semi-natural elements are considered part of cropland (and grassland) and can be mapped separately. Treelines and hedgerows are often easiest to distinguish. Member States are requested to fully document the type of landscape elements included in this class where it is reported separately."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.1> .

# --- Children of 3.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.1" ;
    dcterms:identifier "321" ;
    skos:prefLabel "Mesic grassland"@en ;
    skos:definition "Lowland and montane mesotrophic and eutrophic pastures and hay meadows of the boreal, nemoral, warm-temperate humid and mediterranean zones. They are generally more fertile than dry grasslands. Used to be a common grassland type but has become rare due to agricultural intensification. This vegetation type can be further sub-divided into many different species associations, influenced by soil, climate, altitude and land use management factors. Includes burnt grassland of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.2" ;
    dcterms:identifier "322" ;
    skos:prefLabel "Dry grassland"@en ;
    skos:definition "Well-drained or dry lands dominated by grass or herbs, mostly not fertilized and often of low productivity; composed of native species adapted to the local environment. Included are Artemisia steppes. Excluded are dry Mediterranean lands with shrubs of other genera where the shrub cover exceeds 10%; these are listed as garrigue. This vegetation type can be further sub-divided into many different species associations, influenced by soil, climate, altitude and land use management factors. Includes burnt grassland of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.3" ;
    dcterms:identifier "323" ;
    skos:prefLabel "Seasonally wet and wet grassland"@en ;
    skos:definition "Unimproved or lightly improved wet pastures, meadows and tall herb communities of the boreal, nemoral, warm-temperate humid, steppic and Mediterranean zones. Composed of native species adapted to the local environment. This vegetation type can be further sub-divided into many different species associations, influenced by soil, climate, altitude and land use management factors."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.4" ;
    dcterms:identifier "324" ;
    skos:prefLabel "Alpine and subalpine grasslands"@en ;
    skos:definition "Primary and secondary grass- or sedge- dominated formations of the alpine and subalpine levels of boreal, nemoral, Mediterranean, warm-temperate humid and Anatolian mountains. Composed of native species adapted to the local environment. This vegetation type can be further sub-divided into many different species associations, influenced by soil, climate, altitude and land use management factors."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E4> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.5" ;
    dcterms:identifier "325" ;
    skos:prefLabel "Woodland fringes and clearings and tall forb stands"@en ;
    skos:definition "Stands of tall herbs or ferns, occurring on disused urban or agricultural land, by watercourses, at the edge of woods, or invading pastures. Stands of shorter herbs forming a distinct zone (seam) at the edge of woods."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E5> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.6" ;
    dcterms:identifier "326" ;
    skos:prefLabel "Inland salt steppes"@en ;
    skos:definition "Saline land with dominant salt-tolerant grasses and herbs. Excludes saline shrubland, listed under xero-halophile shrubs."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E6> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.7> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.7" ;
    dcterms:identifier "327" ;
    skos:prefLabel "Holm and cork oak stands with grassy understorey"@en ;
    skos:definition "Grassy vegetation combined with scattered tree stands of holm and cork oak, with a crown cover up to 30% (and generally above 10%), such as Iberian dehesas and montados. Management of the ground layer is focused on grazing use."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/244> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.8> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.8" ;
    dcterms:identifier "328" ;
    skos:prefLabel "Wooded pastures"@en ;
    skos:definition "Temperate or boreal grasslands with a wooded overstorey that normally has at least 5% crown cover. The tree layer is traditionally composed of single oak trees and similar deciduous trees. Associated with traditional herded pastoral systems which have largely disappeared in Europe."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/E7> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2.9> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "3.2.9" ;
    dcterms:identifier "329" ;
    skos:prefLabel "Semi-natural elements associated with agricultural land use in (semi-) natural grassland"@en ;
    skos:definition "Traditional agricultural land use and landscape elements including hedges, ponds, grassy margins etc. as part of the farmed area. Such remaining semi-natural elements are considered part of cropland (and grassland) and can be mapped separately. Treelines and hedgerows are often easiest to distinguish. Member States are requested to fully document the type of landscape elements included in this class where it is reported separately."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/3.2> .

# =========================================================================
# MACRO-ECOSYSTEM 4: Forest and woodland
# =========================================================================

# --- LEVEL 1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:topConceptOf <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4" ;
    dcterms:identifier "4" ;
    skos:prefLabel "Forest and woodland"@en ;
    skos:definition "Forests and woodlands include tree-dominated ecosystems with a canopy cover generally over 30% (in the temperate climate zone) or 10% (in boreal and Mediterranean climate zones) or vegetation where present trees can reach these thresholds in situ. For boreal and Mediterranean forest types a lower threshold is advisable due to extreme climatic conditions, which naturally limit the growth of trees and relative canopy cover."@en ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.6> .

# --- LEVEL 2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1" ;
    dcterms:identifier "41" ;
    skos:prefLabel "Broadleaved deciduous forest"@en ;
    skos:definition "Woodlands and forests dominated by summer-green non-coniferous trees that lose their leaves in winter. Includes woodland with mixed evergreen and deciduous broadleaved trees, provided that the deciduous cover exceeds that of evergreens. The proportion of conifers should not exceed 25%. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/311> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/TF1.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.7> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.8> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.2" ;
    dcterms:identifier "42" ;
    skos:prefLabel "Coniferous forests"@en ;
    skos:definition "Vegetation formation composed principally of trees, including shrub and bush understory, where coniferous species predominate. The proportion of deciduous trees should not exceed 25%. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/312> ;
     skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.1> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.7> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.8> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.9> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.3" ;
    dcterms:identifier "43" ;
    skos:prefLabel "Broadleaved evergreen forest"@en ;
    skos:definition "Forests dominated by broadleaved sclerophyllous or lauriphyllous evergreen trees, or by palms. They are characteristic of the Mediterranean and warm-temperate humid zones. Sporadic grazing use may occur. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.6> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.3> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.4> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.5> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.6> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.3.7> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.4" ;
    dcterms:identifier "44" ;
    skos:prefLabel "Mixed forests"@en ;
    skos:definition "Vegetation formation composed principally of trees, including shrub and bush understorey, where neither broadleaved nor coniferous species strongly predominate (i.e. <75% deciduous and <75% coniferous trees). Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/313> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4.1> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4.2> ,
                  <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.4.3> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.5" ;
    dcterms:identifier "45" ;
    skos:prefLabel "Transitional forest and woodland shrub"@en ;
    skos:definition "Transitional forests and woodland shrub. Includes vegetation that is always shrubland and areas of temporarily cleared forest (as part of forest management). Sporadic grazing use may occur. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4> ;
    skos:exactMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/324> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.1> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T2.2> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T3.2> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.5.1> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.6" ;
    dcterms:identifier "46" ;
    skos:prefLabel "Plantations"@en ;
    skos:definition "Monoculture plantations or plantations strongly dominated by one or few species of non-European coniferous and broadleaved trees with very sparse or lacking undergrowth, e.g. eucalyptus plantations. Forest stands of single or mixed species consisting of native and/or non-native trees species that have long been established in European ecosystems and have diverse undergrowth typical for forest ecosystems should be classified as part of types 4.1 to 4.4. If not possible to distinguish plantations, these areas should be attributed to the classes 4.1 – 4.4. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4> ;
    skos:closeMatch <https://global-ecosystems.org/explore/groups/T7.3> ;
    skos:narrower <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.6.1> .


# --- LEVEL 3 ---

# --- Children of 4.1 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.1" ;
    dcterms:identifier "411" ;
    skos:prefLabel "Riparian forest and woodland"@en ;
    skos:definition "Riparian forests dominated by willows (Salix spp.) and poplars (Populus spp.) of periodically-inundated terraces and shoals; riparian alder (Alnus glutinosa, Alnus incana), and sometimes ash (Fraxinus angustifolia, Fraxinus excelsior), typically without many softwood willows in the canopy and occurring throughout Europe along streams, small to medium rivers and other water bodies; mixed broadleaved forests typical of less-frequently flooded, well-aerated mineral soils on floodplains of the middle and lower reaches of major European rivers. The canopy in high-forest stands can be very tall and multi-layered and is typically dominated by various mixtures of Alnus glutinosa, Fraxinus angustifolia, Fraxinus excelsior, Populus alba, Populus canescens, Prunus padus, Quercus robur, Ulmus glabra, Ulmus laevis and Ulmus minor. Deciduous broadleaved forest, most commonly dominated by poplars (Populus), willows (Salix) or oriental plane (Platanus orientalis), on periodically flooded alluvia or gravel terraces and streamsides in humid localities in the Mediterranean and Macaronesia. Also includes streamside forests with Rhododendron ponticum and Betula pendula var. fontqueri in Spain."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/20985> ,
                    <https://floraveg.eu/habitat/nomenclature/T12> ,
                    <https://eunis.eea.europa.eu/habitats/21025> ,
                    <https://floraveg.eu/habitat/nomenclature/T13> ,
                    <https://floraveg.eu/habitat/nomenclature/T14> ,
                    <https://eunis.eea.europa.eu/habitats/21045> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.2" ;
    dcterms:identifier "412" ;
    skos:prefLabel "Broadleaved swamp forest on non-acid and acid peat"@en ;
    skos:definition "Deciduous broadleaved forest, commonly dominated by alder (Alnus glutinosa, Alnus incana), oak (Quercus robur) or aspen (Populus tremula) on non-acid peat with groundwater at or seasonally above the surface in swamps across the lowlands of the temperate and boreal zones; Deciduous broadleaved or mixed forest on acid peat on or around active bogs and poor fens with nutrient-poor ground waters occurring through the Atlantic region and the boreal zone and locally, where ground conditions permit, also in the continental zone. It is usually dominated by birch (Betula pubescens)."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/21110> ,
                    <https://floraveg.eu/habitat/nomenclature/T15> ,
                    <https://floraveg.eu/habitat/nomenclature/T16> ,
                    <https://eunis.eea.europa.eu/habitats/21129> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.3> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.3" ;
    dcterms:identifier "413" ;
    skos:prefLabel "Fagus dominated forest"@en ;
    skos:definition "Forest dominated by beech (Fagus sylvatica and Fagus orientalis) on base-rich to acid, mesotrophic to eutrophic, mineral soils. Forests dominated by beech, Fagus sylvatica, in western and central Europe, and Fagus orientalis and other Fagus species in southeastern Europe and the Pontic region."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/21135> ,
                    <https://floraveg.eu/habitat/nomenclature/T17> ,
                    <https://floraveg.eu/habitat/nomenclature/T18> ,
                    <https://eunis.eea.europa.eu/habitats/21260> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.4> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.4" ;
    dcterms:identifier "414" ;
    skos:prefLabel "Temperate, Submediterranean and Mediterranean thermophilous deciduous forest"@en ;
    skos:definition "Deciduous or mixed deciduous/evergreen forest of thermophilous and drought-resistant trees, especially oaks (Quercus spp.), a subordinate tier of regionally varied associates, through the submediterranean zones, drier and warmer situations further north, extending into more humid higher altitudes in the mediterranean zone.; Mediterranean deciduous forests usually dominated by Quercus pubescens or, in the Eastern Mediterranean, by Quercus ithaburensis subsp. macrolepis. The canopy is open, either pure or with other oaks. Stands are mostly developed on shallow soil, usually at altitudes of less than 700 m. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/21302> ,
                    <https://floraveg.eu/habitat/nomenclature/T19> ,
                    <https://floraveg.eu/habitat/nomenclature/T1A> ,
                    <https://eunis.eea.europa.eu/habitats/21506> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.5> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.5" ;
    dcterms:identifier "415" ;
    skos:prefLabel "Acidophilous [Quercus]-dominated forests"@en ;
    skos:definition "Oak-dominated forests (mainly Quercus robur and Q. petraea but also other regional species) of impoverished acid soils through the atlantic and continental zones, where beech (Fagus sylvatica) is a potential competitor and extending northwards into the boreal zone where Scot’s pine (Pinus sylvestris) increasingly figures in the canopy. Associated floras are generally rather poor but show some regional distinctiveness and towards the very humid western Atlantic seaboard have extraordinary richness of ferns and cryptogams. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:exactMatch <https://floraveg.eu/habitat/nomenclature/T1B> ;
    skos:exactMatch <https://eunis.eea.europa.eu/habitats/21509> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.6> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.6" ;
    dcterms:identifier "416" ;
    skos:prefLabel "Temperate and boreal and Southern European Betula and Populus tremula forest on mineral soils"@en ;
    skos:definition "Open, low canopy climax birch (Betula litwinowii, Betula pubescens var. glabrata, Betula pubescens var. pumila) and aspen (Populus tremula) forests with a heathy or herb-rich field layer in the boreal zone, temperate mountain ranges including the Caucasus, and temperate zone of Eastern European lowlands; Diverse climax and paraclimax forests dominated by birch (Betula pendula and closely related species) or aspen (Populus tremula) on usually acidic mineral soils in humid ravines and gorges and on unstable substrates in the montane to subalpine belts of the Pyrenees, Corsica, Apennines, Sicily and the southern Balkans. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/21553> ,
                    <https://floraveg.eu/habitat/nomenclature/T1C> ,
                    <https://floraveg.eu/habitat/nomenclature/T1D> ,
                    <https://eunis.eea.europa.eu/habitats/21600> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.7> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.7" ;
    dcterms:identifier "417" ;
    skos:prefLabel "Other broadleaved deciduous forest, excluding highly modified plantations"@en ;
    skos:definition "Various other broadleaved deciduous forest such as Carpinus and Quercus mesic deciduous forest, and ravine forests. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://floraveg.eu/habitat/nomenclature/T1J> ;
    skos:scopeNote "EUNIS categories T1E to T1K applied dynamically."@en .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1.8> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.1.8" ;
    dcterms:identifier "418" ;
    skos:prefLabel "Highly modified broadleaved deciduous forests, in particular plantations including stands of non-native trees species that have long been established in European ecosystems stands"@en ;
    skos:definition "Mixed plantations of deciduous species where at least one species is exotic or outside its natural range, or if composed of native species then managed intensively and planted in mono-age stands. Mono-cultural plantations of recently introduced species should be assigned to 4.6.1. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.1> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/2485> .

# --- Children of 4.2 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.2.1" ;
    dcterms:identifier "421" ;
    skos:prefLabel "Boreal and temperate fir and spruce forest"@en ;
    skos:definition "Evergreen coniferous forest dominated by spruce (Picea abies and, in the Dinaric mountains, relict P. omorika), often with some fir (Abies alba) on usually acidic, even very oligotrophic, wet, cold or rocky soils in the montane and sub-alpine belts of nemoral mountains. Forests of European silver fir (Abies alba) in temperate mountains, often with European beech (Fagus sylvatica), and Norway spruce (Picea abies) where site conditions are harsher at higher altitudes. Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2> ;
    skos:exactMatch <https://floraveg.eu/habitat/nomenclature/T31> ;
    skos:exactMatch <https://eunis.eea.europa.eu/habitats/21856> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "4.2.2" ;
    dcterms:identifier "422" ;
    skos:prefLabel "Mediterranean mountain fir and spruce forest"@en ;
    skos:definition "In the southern Black Sea region and the Caucasus, the dominant species is Caucasian fir (Abies nordmanniana), often with an admixture of Oriental beech (Fagus orientalis) and Oriental spruce (Picea orientalis); Evergreen coniferous forests of more sunless or fog-bound slopes and gullies in the lower to mid altitudinal belts of Mediterranean mountains where firs of very limited distribution dominate in highly distinctive relic stands: Spanish fir (Abies pinsapo), Greek fir (Abies cephalonica), King Boris fir (Abies borisii-regis), Apennine or Sicilian stands of silver fir (Abies alba) and Sicilian fir (Abies nebrodensis). Includes burnt areas of this type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/4.2> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/21910> ,
