    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.3> .

# --- Children of 2.4 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.4.1" ;
    dcterms:identifier "241" ;
    skos:prefLabel "Holm and cork oak stands with arable crop understorey"@en ;
    skos:definition "Crops combined with scattered tree stands of holm and cork oak, with a crown cover up to 30% (and normally above 10%). Management of the ground layer is focused on crop production."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/244> .

<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4.2> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.4.2" ;
    dcterms:identifier "242" ;
    skos:prefLabel "Other agro-forestry area with arable crop understorey"@en ;
    skos:definition "Crops combined with scattered tree stands other than holm and cork oak; with a crown cover up to 30% (and normally above 10%). Management of the ground layer is focused on crop production."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.4> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/244> .

# --- Children of 2.5 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.5.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.5.1" ;
    dcterms:identifier "251" ;
    skos:prefLabel "Mosaic farmland (comprising cropland, grassland and (semi-)natural components)"@en ;
    skos:definition "Mosaic of small cultivated land parcels with different cultivation types -annual crops, pasture and/or permanent crops-, eventually with scattered houses or gardens. Mosaic landscapes have no single dominant land cover that covers more than 50% of the MMU. Includes tree lines, hedgerows and other semi-natural elements in mixed farmland."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.5> ;
    skos:closeMatch <http://dd.eionet.europa.eu/vocabulary/landcover/clc/242> .

# --- Children of 2.6 ---
<https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6.1> a skos:Concept ;
    skos:inScheme <https://w3id.org/italia/env/vocab/ecosystems/typologies> ;
    skos:notation "2.6.1" ;
    dcterms:identifier "261" ;
    skos:prefLabel "Nurseries"@en ;
    skos:definition "Areas dedicated to producing young trees, shrubs, and ornamental species for planting out. Tree and shrub nurseries are the most common type."@en ;
    skos:broader <https://w3id.org/italia/env/vocab/ecosystems/typologies/2.6> ;
    skos:closeMatch <https://eunis.eea.europa.eu/habitats/1772> ,
                    <http://dd.eionet.europa.eu/vocabulary/biodiversity/eunishabitats/FB.1> .

