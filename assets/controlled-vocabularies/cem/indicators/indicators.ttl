<https://w3id.org/italia/env/vocab/cem/indicators/pressures-srb>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures> ;
	skos:prefLabel	"Pressioni SRB"@it , "BTS pressures"@en ;
	dcterms:identifier	"pressures-srb" ;
	skos:definition	"Indicatori relativi allo stato delle stazioni radio base (SRB) per la telefonia mobile."@it , "Indicators describing the state of Base Transceiver Station (BTS)."@en .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-srb-n-siti>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-srb> ;
	skos:prefLabel	"n. siti SRB"@it , "Number of BTS sites"@en ;
	dcterms:identifier	"pre-srb-n-siti" ;
	skos:definition	"numero complessivo delle località, su tutto il territorio regionale, in cui sono installati impianti SRB. Località = indirizzo, oppure, fuori dai centri abitati, la coordinata geografica che individua una località in cui sono installati uno o più impianti. "@it , "total number of locations, across the entire regional territory, where BTS installations are located. Location = address, or, outside inhabited centers, the geographical coordinate identifying a location where one or more installations are set up."@en ;
	skos:notation	"N. siti SRB" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-srb-n-impianti-attivi>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-srb> ;
	skos:prefLabel	"n. impianti SRB attivi"@it , "Number of active BTS installations"@en ;
	dcterms:identifier	"pre-srb-n-impianti-attivi" ;
	skos:definition	"numero complessivo di impianti SRB attivi su tutto il territorio regionale, identificando con un “impianto” l’insieme di sorgenti appartenenti ad uno specifico concessionario (gestore) ed installato in un determinato punto del territorio, su sostegno. "@it , "total number of active BTS installations across the entire regional territory, identifying an 'installation' as the set of sources belonging to a specific concessionaire (operator) and installed at a specific point on the territory, on a support."@en ;
	skos:notation	"N. Impianti SRB attivi" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-srb-n-servizi-attivi>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-srb> ;
	skos:prefLabel	"n. servizi SRB attivi"@it , "Number of active BTS services"@en ;
	dcterms:identifier	"pre-srb-n-servizi-attivi" ;
	skos:definition	"numero complessivo di servizi SRB attivi su tutto il territorio regionale, identificando con un “servizio” la tipologia in base alla tecnologia e alla frequenza "@it , "total number of active BTS services across the entire regional territory, identifying a 'service' as the type based on technology and frequency"@en ;
	skos:notation	"N. servizi SRB attivi" .

