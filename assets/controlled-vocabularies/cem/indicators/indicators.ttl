################################################################################
####################### INDICATORI SUPERAMENTI #################################
################################################################################

<https://w3id.org/italia/env/vocab/cem/indicators/exceedances>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:prefLabel	"Exceedances"@en , "Superamenti"@it ;
	dcterms:identifier	"exceedances" ;
	skos:definition	"Indicatori relativi ai superamenti dei limiti per le sorgenti di campi elettromagnetici (RTV, SRB, ELF)."@it , "Indicators describing limit exceedances for electromagnetic field sources (RTV, BTS, ELF)."@en ;
	skos:topConceptOf	<https://w3id.org/italia/env/vocab/cem/indicators> .

################################################################################
####################### INDICATORI SUPERAMENTI ELF #############################
################################################################################

<https://w3id.org/italia/env/vocab/cem/indicators/exceedances-elf>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/exceedances> ;
	skos:prefLabel	"ELF exceedances"@en , "Superamenti ELF"@it ;
	dcterms:identifier	"exceedances-elf" ;
	skos:definition	"Indicators describing limit exceedances for ELF sources (power lines and substations)."@en , "Indicatori relativi ai superamenti dei limiti per sorgenti ELF (linee elettriche e cabine)."@it .

<https://w3id.org/italia/env/vocab/cem/indicators/exc-elf-n-superamenti>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/exceedances-elf> ;
	skos:prefLabel	"N. superamenti"@it , "number of exceedances"@en ;
	dcterms:identifier	"exc-elf-n-superamenti" ;
	skos:definition	"Numero complessivi dei casi di superamento riscontrati dall’ARPA/APPA durante l’attività di controllo. I casi di superamento possono essere riferiti al limite di esposizione (100 microT per campo magnetico o 5 kV/m per campo elettrico) da applicare in qualsiasi condizione espositiva, al valore di attenzione (10 microT) o all’obiettivo di qualità (3 microT) da applicare in luoghi adibiti a permanenze prolungate (non inferiori alle 4 ore giornaliere)"@it , "Total number of exceedance cases detected by ARPA/APPA during control activities. Exceedance cases may refer to the exposure limit (100 microT for magnetic fields or 5 kV/m for electric fields) to be applied under any exposure condition, the attention value (10 microT), or the quality objective (3 microT) to be applied in places intended for prolonged stays of no less than 4 hours per day"@en ;
	skos:notation	"Numero superamenti" .

################################################################################
####################### INDICATORI SUPERAMENTI RTV SRB #########################
################################################################################

<https://w3id.org/italia/env/vocab/cem/indicators/exceedances-rtv-srb>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/exceedances> ;
	skos:prefLabel	"RTV or BTS exceedances"@en , "Superamenti RTV o SRB"@it ;
	dcterms:identifier	"exceedances-rtv-srb" ;
	skos:definition	"Indicators describing limit exceedances for radio and television broadcasting installations (RTV) or BTS installations."@en , "Indicatori relativi ai superamenti dei limiti per impianti radiotelevisivi (RTV) o SRB."@it .

<https://w3id.org/italia/env/vocab/cem/indicators/exc-rtv-srb-n-superamenti>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/exceedances-rtv-srb> ;
	skos:prefLabel	"N. superamenti"@it , "number of exceedances"@en ;
	dcterms:identifier	"exc-rtv-srb-n-superamenti" ;
	skos:definition	"Numero complessivi dei casi di superamento riscontrati dall’ARPA/APPA durante l’attività di controllo. I casi di superamento possono essere riferiti al limite di esposizione (20 V/m per frequenze comprese tra 3Mhz e 3GHz e 40V/m per frequenze> 3 GHz) da applicare a qualsiasi conditione espositiva, al valore di attenzione 15 V/m (o 6 V/m per casi antecedenti l’entrata in vigore dei nuovi limiti normativi con Legge 214/2023) da applicare in luoghi adibiti a permanenze prolungate (non inferiori alle 4 ore giornaliere)."@it , "Total number of exceedance cases detected by ARPA/APPA during control activities. Exceedance cases may refer to the exposure limit (20 V/m for frequencies between 3MHz and 3GHz and 40V/m for frequencies > 3 GHz) to be applied to any exposure condition, or to the attention value of 15 V/m (or 6 V/m for cases prior to the entry into force of the new regulatory limits under Law 214/2023) to be applied in places intended for prolonged stays of no less than 4 hours per day."@en ;
	skos:notation	"Numero superamenti" .

