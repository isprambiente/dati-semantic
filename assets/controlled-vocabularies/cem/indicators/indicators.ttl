################################################################################
####################### INDICATORI PRESSIONI RTV ###############################
################################################################################

<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures> ;
	skos:prefLabel	"RTV pressures"@en , "Pressioni RTV"@it ;
	dcterms:identifier	"pressures-rtv" ;
	skos:definition	"Indicatori relativi allo stato degli impianti radiotelevisivi (RTV)."@it , "Indicators describing the state of radio and television broadcasting installations (RTV)."@en .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-rtv-n-siti>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv> ;
	skos:prefLabel	"N. Siti RTV"@it , "Number of RTV sites"@en ;
	dcterms:identifier	"pre-rtv-n-siti" ;
	skos:definition	"numero complessivo delle località, su tutto il territorio regionale, in cui sono installati impianti RTV. Località = indirizzo, oppure, fuori dai centri abitati, la coordinata geografica che individua una località in cui sono installati uno o più impianti. "@it , "total number of locations, across the entire regional territory, where RTV installations are located. Location = address, or, outside inhabited centers, the geographical coordinate identifying a location where one or more installations are set up."@en ;
	skos:notation	"N. Siti RTV" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-rtv-n-impianti-attivi>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv> ;
	skos:prefLabel	"n. impianti RTV attivi"@it , "Number of active RTV installations"@en ;
	dcterms:identifier	"pre-rtv-n-impianti-attivi" ;
	skos:definition	"numero complessivo di impianti RTV attivi su tutto il territorio regionale, intendendo per “impianto” l’elemento associabile ad una determinata frequenza di trasmissione, installato in un determinato punto del territorio, su sostegno."@it , "total number of active RTV installations across the entire regional territory, where 'installation' refers to the element associated with a specific transmission frequency, installed at a specific point on the territory, on a support."@en ;
	skos:notation	"N. impianti RTV attivi" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-rtv-potenza-impianti-attivi-kw>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv> ;
	skos:prefLabel	"Potenza complessiva impianti RTV attivi"@it , "Total power of active RTV installations"@en ;
	dcterms:identifier	"pre-rtv-potenza-impianti-attivi-kw" ;
	skos:definition	"la potenza complessiva (in esercizio; kW) degli impianti RTV attivi sul territorio regionale. "@it , "the total power (in operation; kW) of active RTV installations within the regional territory."@en ;
	skos:notation	"Potenza complessiva impianti RTV attivi (kW)" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-rtv-n-impianti-autorizzati>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv> ;
	skos:prefLabel	"n. impianti autorizzati RTV"@it , "Number of authorized RTV installations"@en ;
	dcterms:identifier	"pre-rtv-n-impianti-autorizzati" ;
	skos:definition	"numero totale di impianti valutati con parere tecnico delle ARPA/APPA che non risultano ancora attivi."@it , "total number of installations evaluated with a technical opinion by ARPA/APPA that are not yet active."@en ;
	skos:notation	"N. impianti RTV autorizzati" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-rtv-potenza-autorizzati-kw>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv> ;
	skos:prefLabel	"Potenza complessiva impianti RTV autorizzati"@it , "Total power of authorized RTV installations"@en ;
	dcterms:identifier	"pre-rtv-potenza-autorizzati-kw" ;
	skos:definition	"potenza complessiva (in esercizio; kW) degli impianti RTV autorizzati sul territorio regionale che non risultano ancora attivi."@it , "total power (in operation; kW) of authorized RTV installations within the regional territory that are not yet active."@en ;
	skos:notation	"Potenza complessiva RTV autorizzati (kW)" .

<https://w3id.org/italia/env/vocab/cem/indicators/pre-rtv-note>
	a	skos:Concept ;
	skos:inScheme	<https://w3id.org/italia/env/vocab/cem/indicators> ;
	skos:broader	<https://w3id.org/italia/env/vocab/cem/indicators/pressures-rtv> ;
	skos:prefLabel	"Note"@it , "Notes"@en ;
	dcterms:identifier	"pre-rtv-note" ;
	skos:definition	"informazioni utili "@it , "useful information"@en ;
